        part deliverableTestGateDoDR11 : TestResult { :>> id = "b073aa95-5ff3-4536-b493-31b93075059e"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "20d87e5"; :>> judgedAt = "2026-07-18"; :>> judgedBy = "claudeOpus"; }
