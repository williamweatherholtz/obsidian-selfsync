    // ---- Standard critique round (2026-07, 3 lenses: data-integrity + security + sync). 6 FIXED +
    // real-tested (critRoundStd), 4 accepted/deferred (critRoundResidual). ----
    part issueCritDeltaGuard : Issue { :>> id = "c0f1a5cc-c001-4a10-9b20-a1b2c3d4c001"; :>> title = "reconcileDelta doesn't supply locallyPresent → C1 guard inert on the poll-delta path"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "KEYSTONE (found independently by the data-integrity AND sync critics, same reconcile.ts:396 citation): the incremental delta path called reconcileOne without locallyPresent, so the C1 'present-but-unreadable != deleted' guard was dead there. A momentarily-unreadable file (AV lock / unhydrated cloud placeholder) during a poll delta could be mis-decided as an unguarded delete-remote (wiping a fully-synced note fleet-wide) or cleared-then-resurrected. RESOLVED: reconcileDelta probes io.exists (defaulting to present) and passes locallyPresent, so the guard fires (skip + retry). Class: silent divergence / data loss."; :>> discoveredInField = false; :>> relatedTask = "critRoundStd"; :>> severity = Severity::High; }
    part issueCritCommitDoS : Issue { :>> id = "c0f1a5cc-c002-4a10-9b20-a1b2c3d4c002"; :>> title = "Authenticated memory-amplification DoS via concurrent large commits"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "A single commit is bounded to req.size <= MAX_FILE_BYTES (512 MiB), but a client owning up to 100 vaults could fire many ~512 MiB reassemblies concurrently (each transient) and OOM a modest box. RESOLVED: large commits (req.size > 16 MiB) acquire a small global permit pool (MAX_CONCURRENT_LARGE_COMMITS=4) with a 30s bounded wait (503 on shed); small note commits are unthrottled — aggregate large-reassembly RAM is bounded. Class: availability."; :>> discoveredInField = false; :>> relatedTask = "critRoundStd"; :>> severity = Severity::High; }
    part issueCritRestoreCas : Issue { :>> id = "c0f1a5cc-c003-4a10-9b20-a1b2c3d4c003"; :>> title = "delete-local restore push had no CAS → lost update"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "The tombstone-authoritative 'restore, never destroy' branch pushed with no expectedVersion, so a peer that created the path between this device's manifest read and the restore commit was silently overwritten. RESOLVED: the restore commits with expectedVersion 0 ('expected absent') → a concurrent create 409s → next reconcile merges. Class: recoverable-but-wrong."; :>> discoveredInField = false; :>> relatedTask = "critRoundStd"; :>> severity = Severity::Medium; }
    part issueCritDownloadSwitch : Issue { :>> id = "c0f1a5cc-c004-4a10-9b20-a1b2c3d4c004"; :>> title = "'download' vault-switch bypassed the bulk-delete guard"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "switchTo('download') removed every accepted local file absent from the target manifest with no ratio guard; a target reindexed over a PARTIAL directory reports status:ready while missing files, so mirroring it mass-deleted legitimate local-only notes (recoverable via .trash). RESOLVED: the same BULK_DELETE ratio guard reconcileAll uses now gates the download-mode removal — a suspiciously-incomplete manifest keeps local files (surfaced via onGuard); a genuine populated target still mirrors. Class: recoverable-but-wrong."; :>> discoveredInField = false; :>> relatedTask = "critRoundStd"; :>> severity = Severity::Medium; }
    part issueCritWsMustChange : Issue { :>> id = "c0f1a5cc-c005-4a10-9b20-a1b2c3d4c005"; :>> title = "must_change gate not enforced on the WebSocket path"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "The AuthToken extractor blocks a forced-change account on all HTTP routes, but ws_handler resolved the token manually and skipped the check, so a locked account could still open change-notification subscriptions (metadata only, ACL-gated). RESOLVED: ws_handler now rejects a must_change account with 403, mirroring the extractor. Class: authz gate gap."; :>> discoveredInField = false; :>> relatedTask = "critRoundStd"; :>> severity = Severity::Medium; }
    part issueCritRealtimeStale : Issue { :>> id = "c0f1a5cc-c006-4a10-9b20-a1b2c3d4c006"; :>> title = "realtimeConnected stale-true after a non-network reconcile failure"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "On a non-socket failure the close handler's superseded-socket early-return left realtimeConnected true, so the status light briefly showed green 'Fully synced' during connect->idle before the new socket opened. RESOLVED: doConnect resets realtimeConnected=false up front. Class: cosmetic/stale indicator."; :>> discoveredInField = false; :>> relatedTask = "critRoundStd"; :>> severity = Severity::Low; }
    part issueCritOpenEnum : Issue { :>> id = "c0f1a5cc-c007-4a10-9b20-a1b2c3d4c007"; :>> title = "Open-registration mode leaks username existence (enumeration)"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "In open-registration mode /api/register returns 409 for a taken username vs 200 for a free one. ACCEPTED/DEFERRED: open mode lets anyone create accounts, so existence is inherently low-value, and de-oracling it harms the UX (a user must be told a name is taken to pick another). Documented as an open-mode property; the closed-mode path is already de-oracled. Class: info leak (accepted tradeoff)."; :>> discoveredInField = false; :>> relatedTask = "critRoundResidual"; :>> severity = Severity::Low; }
    part issueCritTotpReplay : Issue { :>> id = "c0f1a5cc-c008-4a10-9b20-a1b2c3d4c008"; :>> title = "TOTP codes replayable within their ~90s window (no last-step tracking)"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "totp::verify accepted step +/-1 with no last-consumed step recorded, so a captured code was replayable for the rest of its window. RESOLVED: users.rs now records the last consumed 30s step per user (totp_last_step); totp_verify_second_factor rejects a code whose step <= the last (RFC 6238 s5.2). Test: totp_code_cannot_be_replayed_within_its_window. Class: hardening."; :>> discoveredInField = false; :>> relatedTask = "critResidualEasy"; :>> severity = Severity::Low; }
    part issueCritWsLiveness : Issue { :>> id = "c0f1a5cc-c009-4a10-9b20-a1b2c3d4c009"; :>> title = "No client-side WebSocket liveness check (half-open socket stalls realtime)"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "The client treated the WS as healthy until the browser fired close; a half-open socket (radio sleep / NAT rebind) kept realtimeConnected true with the poll downshifted, so the light showed green over a dead channel. RESOLVED: the server sends an application heartbeat every ~30s (ws.rs) that the client CAN see (browsers hide protocol ping/pong from JS), and the client runs a liveness timer (isWsStale) that drops realtime health + upshifts the poll + re-dials if no frame arrives within WS_STALE_MS (~75s). Test: syncstate.test isWsStale. Class: latency / misleading state."; :>> discoveredInField = false; :>> relatedTask = "critResidual2"; :>> severity = Severity::Medium; }
    part issueCritMobileFsync : Issue { :>> id = "c0f1a5cc-c00a-4a10-9b20-a1b2c3d4c00a"; :>> title = "Mobile buffered write is not fsync-durable (crash-window delete-remote)"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "On mobile io.write can't fsync, so a pulled note's bytes can sit in cache while data.json (the base map) persists; a crash in that window leaves the note absent-on-disk but base==remote, which decide() resolves to delete-remote. ACCEPTED/DEFERRED: inherent to the mobile adapter's lack of an fsync API; desktop is durable. Mitigation options (persist base only after a read-back barrier) tracked. Class: durability (platform-inherent, accepted)."; :>> discoveredInField = false; :>> relatedTask = "critRoundResidual"; :>> severity = Severity::Medium; }
