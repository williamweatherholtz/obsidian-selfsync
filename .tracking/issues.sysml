    // =====================================================================
    // ROUND 2 — a THIRD fresh 3-lens adversarial critique (independent critics) against the
    // 0.10.17-hardened code, 2026-07-05. 16 NEW findings; 15 fixed + shipped 0.10.18
    // (#Resolves round2CriticFixes, done); several exposed GAPS in the Round-1 fixes themselves
    // (unverified cached chunks bypassing DI-2; stranded requeue from CONC#6; SEC#1 not covering
    // in-vault file paths). The 1 residual (large-file pull TOCTOU) is inherent + accepted.
    // =====================================================================
    part issueCacheUnverified : Issue { :>> id = "c0f1a5cc-9401-4a10-9b20-a1b2c3d49401"; :>> title = "Cached chunks bypassed DI-2 verification, laundering server bit-rot into a streamed file"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R2#1 (HIGH): fetchFileBytes cached chunks unverified and streamFileToDisk verified only on a cache MISS, so a corrupt blob cached during an aborted buffered fetch was trusted on a later dedup cache hit and re-pushed as canonical corruption. Fixed: getVerifiedChunk verifies before caching in both paths. +test."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::High; }
    part issuePullGapsStreamCreate : Issue { :>> id = "c0f1a5cc-9402-4a10-9b20-a1b2c3d49402"; :>> title = "DI-3 racing-edit guard missed the streamed branch and the racing-create case"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R2#2/#4: applyPull's guard ran only on the buffered path and only when the local file was present, so a large-file stream (or a racing local CREATE of an expected-absent path) silently clobbered local content. Fixed: shared conflictCopyIfRaced + guardRace flag covering both paths and the absent-expected case."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueMergeBaseDesync : Issue { :>> id = "c0f1a5cc-9403-4a10-9b20-a1b2c3d49403"; :>> title = "pushBytes discarded committed bytes; clean-merge base could record disagreeing (text,hash)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R2#3: the merge path set base from pre-write merged bytes while the hash came from pushFile's re-read — a racing save between them desynced base.text vs base.hash, poisoning the next merge's ancestor. Fixed: pushBytes returns PushResult; base recorded from committed bytes (DI-5 on the merge path)."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueConflictCopyStale : Issue { :>> id = "c0f1a5cc-9404-4a10-9b20-a1b2c3d49404"; :>> title = "Merge/conflict copies preserved the stale pre-fetch local read, not a racing edit"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R2#5: the merge/conflict-copy and read-only-share fallbacks wrote the localBytes read before the remote fetch as the conflict copy, so an edit made DURING the fetch was lost. Fixed: re-read current on-disk bytes for the copy. Also: bulk-delete ratio denominator now counts only accepted base paths (note)."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueDrainStranded : Issue { :>> id = "c0f1a5cc-9405-4a10-9b20-a1b2c3d49405"; :>> title = "A re-queued edit was stranded on the idle-poll short-circuit under a green light"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R2#1 (HIGH): onRemoteChanged's idle short-circuit returned before the drainPending() call, so a path re-queued by the CONC#6 fix was never retried while syncDone flipped the light green over the unsynced edit. Fixed: drainPending runs in the finally on every path."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::High; }
    part issueDirectOpNoRequeue : Issue { :>> id = "c0f1a5cc-9406-4a10-9b20-a1b2c3d49406"; :>> title = "A directly-attempted local op that failed was neither re-queued nor retried"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R2#2: onLocalEvent/Delete/Rename only logged on catch, relying on the next full reconcile; on an idle remote a transient failure left the edit unsynced for a long time. Fixed: re-queue the path(s) into pendingLocal on catch so the drain retries."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueVersionRewindPin : Issue { :>> id = "c0f1a5cc-9407-4a10-9b20-a1b2c3d49407"; :>> title = "Math.max version cursor pinned high after a server rewind, forcing a full reconcile every poll"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R2#3: reconcileAll/switchTo advanced the cursor with Math.max, so after a server reindex/restore rewound the version, every idle poll saw a mismatch and re-ran a full reconcile forever. Fixed: ASSIGN resp.version after a full reconcile (the client is consistent with it), so the incremental path converges."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueWsRedialRaces : Issue { :>> id = "c0f1a5cc-9408-4a10-9b20-a1b2c3d49408"; :>> title = "WS self-heal redial: stale-timer race, backoff inflation on lock-defer, expired-token redial storm"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R2#4/#5/#6: the CONC#3 redial could be armed by the old socket during a reconnect (racing it on failure); deferring reconnect for the applying lock doubled backoff toward the cap; a socket that never opened (expired token) re-dialed every 3s with the dead token. Fixed: reconnect cancels wsRedialTimer; lock-defer passes bumpBackoff=false; a never-opened socket escalates to a full reconnect."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Low; }
    part issueSelfFolderCase : Issue { :>> id = "c0f1a5cc-9409-4a10-9b20-a1b2c3d49409"; :>> title = "Case-sensitive self-folder exclusion let a shared vault overwrite the victim's SelfSync credentials"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R2#1 (MED, connection hijack): shouldSync compared the self-folder path case-sensitively while SEC#1 canonicalized only user/vault segments (not in-vault file paths), so a shared-vault owner committing .obsidian/plugins/NEW-LIVESYNC/data.json overwrote the victim's stored server URL+creds on a case-insensitive FS. Fixed: case-insensitive self-folder exclusion. +test."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueReindexJunkBrick : Issue { :>> id = "c0f1a5cc-940a-4a10-9b20-a1b2c3d4940a"; :>> title = "A committed junk-named file (.DS_Store/.git) permanently bricks reindex (cross-account)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R2#2: commit accepted names that reindex's collect_files skips as junk, so a later reindex counted them as 'indexed file missing from disk' (DI-4) and aborted every time — leaving the vault stuck in ERROR; a readWrite grantee could inflict it on the owner. Fixed: safe_rel_path rejects junk basenames. +test."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueWsRevokeLeak : Issue { :>> id = "c0f1a5cc-940b-4a10-9b20-a1b2c3d4940b"; :>> title = "Share revocation didn't evict an in-flight WebSocket; revoked grantee kept getting change metadata"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R2#3: the WS authorized only at connect and never re-checked, so after share_delete the grantee's open socket kept receiving {type:changed,version} frames (content stays protected by per-request HTTP re-auth, but edit-timing + version counts leaked). Fixed: re-check the ACL before forwarding each notification; drop on revoke."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Low; }
    part issueAdminCreateArgon : Issue { :>> id = "c0f1a5cc-940c-4a10-9b20-a1b2c3d4940c"; :>> title = "Admin users_create bypassed the SEC-2 password cap + argon2 blocking-thread/semaphore"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R2#4: users_create hashed on the async runtime with no length cap, outside the auth_slots/spawn_blocking path (admin-gated, so low impact, matters more under ALLOW_WEAK_ADMIN=1). Fixed: enforce MAX_PASSWORD_LEN + run via the semaphore-bounded blocking path."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Low; }
    part issuePullTOCTOUResidual : Issue { :>> id = "c0f1a5cc-940d-4a10-9b20-a1b2c3d4940d"; :>> title = "Residual TOCTOU in the pull racing-edit check (edit landing between hash and write)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R2#7 / DI-adjacent (ACCEPT — inherent): the DI-3 disk re-check narrows but cannot fully close the window, since a local save can land between curHash and the final io.write; closing it entirely would require blocking Obsidian's own disk writes. Accepted as an inherent narrowing; the common cases are guarded."; :>> discoveredInField = false; :>> relatedTask = "round1DeferredHardening"; :>> severity = Severity::Low; }

    #Resolves dependency from round2CriticFixes to issueCacheUnverified;
    #Resolves dependency from round2CriticFixes to issuePullGapsStreamCreate;
    #Resolves dependency from round2CriticFixes to issueMergeBaseDesync;
    #Resolves dependency from round2CriticFixes to issueConflictCopyStale;
    #Resolves dependency from round2CriticFixes to issueDrainStranded;
    #Resolves dependency from round2CriticFixes to issueDirectOpNoRequeue;
    #Resolves dependency from round2CriticFixes to issueVersionRewindPin;
    #Resolves dependency from round2CriticFixes to issueWsRedialRaces;
    #Resolves dependency from round2CriticFixes to issueSelfFolderCase;
    #Resolves dependency from round2CriticFixes to issueReindexJunkBrick;
    #Resolves dependency from round2CriticFixes to issueWsRevokeLeak;
    #Resolves dependency from round2CriticFixes to issueAdminCreateArgon;
    #Resolves dependency from round1DeferredHardening to issuePullTOCTOUResidual;

    // =====================================================================
    // ROUND 3 — a FOURTH fresh 3-lens critique (independent critics) vs the 0.10.18 code,
    // 2026-07-05. 8 NEW findings (convergence: 18 → 16 → 8, severity falling). 6 fixed + shipped
    // 0.10.19 (#Resolves round3CriticFixes); 2 deferred (#Resolves round1DeferredHardening). Two
    // of the fixed were GAPS in Round-2 fixes (clean-merge stale local; Lagged skipping the ACL).
    // =====================================================================
    part issueMergeStaleLocal : Issue { :>> id = "c0f1a5cc-9501-4a10-9b20-a1b2c3d49501"; :>> title = "Clean auto-merge fed stale localBytes into merge3, silently dropping a save that raced the fetch"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R3#1 (MED-HIGH): the DI-R2#5 fix re-read current disk for the conflict-copy + read-only paths but NOT the clean-merge branch, which still merged base+STALE-local+remote and overwrote disk — losing keystrokes autosaved during the multi-chunk fetch, with no conflict copy. Fixed: re-read current disk (liveLocal) after the fetch and use it for the whole merge/conflict decision."; :>> discoveredInField = false; :>> relatedTask = "round3CriticFixes"; :>> severity = Severity::High; }
    part issueWsRedialMidReconnect : Issue { :>> id = "c0f1a5cc-9502-4a10-9b20-a1b2c3d49502"; :>> title = "A WS redial armed mid-reconnect wasn't cancelled on the reconnect-failure path"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R3#1: the CONC-R2#4 clear ran only at reconnect ENTRY, so a redial armed by the old socket's close DURING the reconnect's awaits survived a failed reconnect and fired spinUpWs with a stale token, racing the backoff reconnect. Fixed: scheduleReconnect cancels any pending wsRedialTimer (a full reconnect supersedes a redial)."; :>> discoveredInField = false; :>> relatedTask = "round3CriticFixes"; :>> severity = Severity::Low; }
    part issueRemoteChangeDropped : Issue { :>> id = "c0f1a5cc-9503-4a10-9b20-a1b2c3d49503"; :>> title = "A remote notification arriving during an active reconcile was dropped (waited for the 4s poll)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R3#3: onRemoteChanged returned on the applying guard without noting the pending remote change, so a commit landing mid-reconcile synced only at the next 4s poll (losing the WS's instant property). Fixed: a remoteDirty flag re-runs onRemoteChanged once the current reconcile finishes."; :>> discoveredInField = false; :>> relatedTask = "round3CriticFixes"; :>> severity = Severity::Low; }
    part issueLaggedNoAcl : Issue { :>> id = "c0f1a5cc-9504-4a10-9b20-a1b2c3d49504"; :>> title = "The WS Lagged arm skipped the per-notification ACL re-check (revoked-but-lagging grantee leak)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R3#2: the SEC-R2#3 ACL re-check was only on the Ok(version) arm; a continuously-lagging revoked grantee kept getting {type:changed} activity nudges (timing metadata; no version/paths, follow-up reads are 403). Fixed: re-check the ACL in the Lagged arm too and break if unauthorized."; :>> discoveredInField = false; :>> relatedTask = "round3CriticFixes"; :>> severity = Severity::Low; }
    part issueTrailingNameDesync : Issue { :>> id = "c0f1a5cc-9505-4a10-9b20-a1b2c3d49505"; :>> title = "Trailing-dot/space names bypassed safe_rel_path, desyncing index key vs on-disk name (Windows)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R3#1 (MED): safe_rel_path didn't reject a component ending in '.' or space (or all-dots), which Windows strips on write — so index key 'evil.md.' != on-disk 'evil.md', re-opening the DI-4 reindex-brick, and 'aux ' evaded the reserved-device check (→ AUX). Fixed: reject trailing-dot/space + all-dot components (safe superset on Linux). +test."; :>> discoveredInField = false; :>> relatedTask = "round3CriticFixes"; :>> severity = Severity::Medium; }
    part issuePurgeOrdering : Issue { :>> id = "c0f1a5cc-9506-4a10-9b20-a1b2c3d49506"; :>> title = "Account-delete removed the user row before a best-effort data purge; a failed purge left inheritable data"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R3#2 (SEC-MED-2 residual): users_delete removed the users.json row first, then purged data best-effort (WARN on failure), so a locked-file purge failure left DATA_ROOT/<name>/ for a same-name recreation to inherit. Fixed: purge data FIRST and hard-error on failure, so a failure leaves the account intact + retryable and the row is removed only once data is provably gone."; :>> discoveredInField = false; :>> relatedTask = "round3CriticFixes"; :>> severity = Severity::Low; }
    // ---- deferred (round1DeferredHardening, OPEN) ----
    part issueStreamWholeHash : Issue { :>> id = "c0f1a5cc-9507-4a10-9b20-a1b2c3d49507"; :>> title = "Streamed download verifies each chunk but not the reassembled whole-file hash (wrong chunk LIST)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R3#2 (LOW, DEFERRED): streamFileToDisk verifies each chunk's content address but not that the concatenation equals rmeta.hash, so a wrong chunk LIST (valid chunks, wrong order/set) isn't caught the way the buffered fetchVerified catches it. Not a live path (chunk lists are verified at commit; corrupt manifest JSON → ERROR state, not a valid-but-wrong list) and a true streaming whole-file verify needs an incremental SHA-256 the client's WebCrypto (one-shot digest) doesn't provide without buffering. Deferred defense-in-depth parity."; :>> discoveredInField = false; :>> relatedTask = "round1DeferredHardening"; :>> severity = Severity::Low; }
    part issueReindexSingleChunk : Issue { :>> id = "c0f1a5cc-9508-4a10-9b20-a1b2c3d49508"; :>> title = "reindex stores each whole file as ONE chunk, defeating client streaming + the chunk-size ceiling"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R3#3 (LOW, DEFERRED): reindex (operator recovery) rebuilds from materialized files but stores each whole file as a single blob, so a large reindexed file becomes one huge chunk that getVerifiedChunk buffers whole (OOM risk on mobile) until the file is next edited client-side. Content stays correct + hash-verified. Fixing needs a Rust CDC chunker matching the client's gear-hash — a tracked enhancement; low real-world impact (operator-triggered, self-corrects on next edit)."; :>> discoveredInField = false; :>> relatedTask = "round1DeferredHardening"; :>> severity = Severity::Low; }

    #Resolves dependency from round3CriticFixes to issueMergeStaleLocal;
    #Resolves dependency from round3CriticFixes to issueWsRedialMidReconnect;
    #Resolves dependency from round3CriticFixes to issueRemoteChangeDropped;
    #Resolves dependency from round3CriticFixes to issueLaggedNoAcl;
    #Resolves dependency from round3CriticFixes to issueTrailingNameDesync;
    #Resolves dependency from round3CriticFixes to issuePurgeOrdering;
    #Resolves dependency from round1DeferredHardening to issueStreamWholeHash;
    #Resolves dependency from round1DeferredHardening to issueReindexSingleChunk;

    // =====================================================================
    // ROUND 4 — a FIFTH fresh 3-lens critique vs the 0.10.19 code, 2026-07-05. Convergence:
    // 18 → 16 → 8 → 2 NEW findings. SECURITY LENS CONVERGED (0 findings — every attack surface
    // traced, all prior fixes confirmed present+correct). 2 fixed + shipped 0.10.20
    // (#Resolves round4CriticFixes); 1 sub-LOW cosmetic accepted (#Resolves round1DeferredHardening).
    // =====================================================================
    part issueNoncanonicalPath : Issue { :>> id = "c0f1a5cc-9601-4a10-9b20-a1b2c3d49601"; :>> title = "Non-canonical path (notes//a.md, trailing slash) desyncs the raw index key from the on-disk name"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R4#1 (MED): commit used the RAW req.path as the index key but derived the on-disk mirror from a Path-normalized value that collapses redundant/trailing slashes, so a non-conforming/hostile client could commit two keys (notes/a.md + notes//a.md) aliasing ONE disk file (silent overwrite + double manifest entry → client phantom-delete ping-pong), or desync key-vs-disk (reindex brick). Same integrity boundary as the case-collision/junk/trailing-dot guards. Fixed: safe_rel_path rejects any path that isn't its own canonical forward-slash form. +test."; :>> discoveredInField = false; :>> relatedTask = "round4CriticFixes"; :>> severity = Severity::Medium; }
    part issueRemoteDirtyCoverage : Issue { :>> id = "c0f1a5cc-9602-4a10-9b20-a1b2c3d49602"; :>> title = "remoteDirty instant re-run honored only on the onRemoteChanged exit path (poke dropped to poll latency elsewhere)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R4#1 (LOW): the CONC-R3#3 remoteDirty re-run fired only in onRemoteChanged's finally (and even there drainPending could grab the lock first), so a remote poke arriving during other local activity (drain/reconnect/config-flush/delete/rename) waited for the 4s poll — losing the WS instant property (not data loss; poll backstops). Fixed: centralized the remoteDirty re-run into drainPending's exit, which every applying-releasing path already calls."; :>> discoveredInField = false; :>> relatedTask = "round4CriticFixes"; :>> severity = Severity::Low; }
    part issueTransientGreenLight : Issue { :>> id = "c0f1a5cc-9603-4a10-9b20-a1b2c3d49603"; :>> title = "Transient 'fully synced' green light while polling is briefly stopped after a blip"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R4 cosmetic (sub-LOW, ACCEPT): after a transient reconcile error stops the poll timer + schedules reconnect, a queued edit succeeding in the same finally dispatches syncDone → FSM offline+syncDone→idle (green) while the poll interval is momentarily stopped, until the reconnect timer restarts it. Self-correcting within the backoff window, no data impact — a sub-second wrong indicator not worth a code change on its own. Accepted."; :>> discoveredInField = false; :>> relatedTask = "round1DeferredHardening"; :>> severity = Severity::Low; }

    #Resolves dependency from round4CriticFixes to issueNoncanonicalPath;
    #Resolves dependency from round4CriticFixes to issueRemoteDirtyCoverage;
    #Resolves dependency from round1DeferredHardening to issueTransientGreenLight;

    // =====================================================================
    // ROUND 5 — the HOLISTIC + completeness + final-adversary round vs 0.10.20, 2026-07-05.
    // The final cross-boundary adversary found 5 LOW/LOW-MED (3 fixed → 0.10.21, 2 cosmetic/CAS
    // tracked) and VERIFIED the cross-cutting invariants sound. The holistic reviewer's verdict:
    // the data-safety core holds; remaining gaps are robustness/coverage/operability ENHANCEMENTS
    // (tracked open under round5CompletenessFollowups, to land before a broad release), not defects.
    // =====================================================================
    // ---- fixed in 0.10.21 (round5CriticFixes) ----
    part issueUnicodeCaseCollision : Issue { :>> id = "c0f1a5cc-9701-4a10-9b20-a1b2c3d49701"; :>> title = "PROTO-4 case-collision guard folded ASCII only; a Unicode case pair (café/CAFÉ) evaded it"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R5#1 (LOW-MED, deployment-conditional): eq_ignore_ascii_case let café.md and CAFÉ.md both enter the index while a case-insensitive Unicode-folding FS (macOS/Windows) collapses them to one file → reindex brick + phantom-delete; a readWrite grantee could inflict it. Fixed: fold full Unicode case (to_lowercase) in the collision check. +test."; :>> discoveredInField = false; :>> relatedTask = "round5CriticFixes"; :>> severity = Severity::Medium; }
    part issueLegacyKeyUndeletable : Issue { :>> id = "c0f1a5cc-9702-4a10-9b20-a1b2c3d49702"; :>> title = "A legacy file whose name the tightened safe_rel_path now rejects was undeletable (404 loop)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R5#4 (LOW, upgrade-only): delete() returned None for a name safe_rel_path now rejects, so a file committed before the tightening (or ingested via bind-mount+reindex) 404-looped on every client delete-remote and its tombstone never propagated. Fixed: if the exact index key is present, evict it even when the name is now invalid (skip only the on-disk mirror removal). +test."; :>> discoveredInField = false; :>> relatedTask = "round5CriticFixes"; :>> severity = Severity::Low; }
    part issueDeleteRevokeRace : Issue { :>> id = "c0f1a5cc-9703-4a10-9b20-a1b2c3d49703"; :>> title = "Account delete didn't revoke the token before purge (data-remanence self-race)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R5#2 (LOW): between purge_user_data and revoke_user, the victim's still-valid token could create_vault / land an in-flight commit, re-materializing DATA_ROOT/<name>/ after remove_dir_all for a same-name recreation to inherit. Fixed: revoke tokens FIRST, then purge, then remove the row."; :>> discoveredInField = false; :>> relatedTask = "round5CriticFixes"; :>> severity = Severity::Low; }
    // ---- completeness/robustness enhancements, tracked OPEN (round5CompletenessFollowups) ----
    part issueVersionHandshake : Issue { :>> id = "c0f1a5cc-9704-4a10-9b20-a1b2c3d49704"; :>> title = "No client<->server protocol/schema version negotiation (independent-upgrade skew is undiagnosable)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "Holistic#1 (MED, OPEN): /health returns bare 'ok'; no apiVersion field, no min-client check, and the on-disk Index has no schema tag. The plugin auto-updates (BRAT) independently of the server, so version skew is the most likely real-world breakage — and it surfaces as a generic 'malformed response' retry loop (SAFE, never mutates, but undiagnosable) or a scary CORRUPT→reindex. Add a version handshake + a clear 'incompatible, upgrade' message. Pre-broad-release."; :>> discoveredInField = false; :>> relatedTask = "round5CompletenessFollowups"; :>> severity = Severity::Medium; }
    part issueOrchestrationUntested : Issue { :>> id = "c0f1a5cc-9705-4a10-9b20-a1b2c3d49705"; :>> title = "The imperative main.ts orchestration layer (incl. 2 MUST reqs + the SEC-3 gate + WS push) has no automated tests"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "Holistic#2/#3/#4 (MED, OPEN): srConfigLiveDetect + srSelfHealingReconnect (both priority=must), the SEC-3 no-plugin-code-from-shared-vault gate, and WS instant-push + revocation eviction are verified by inspect+attestation only — reconnect/scheduleReconnect/connectWs/onRawConfigEvent/flushRawConfig/flushConfigReload have zero test references. This is the 0.10.4-escape code family; a regression wouldn't fail CI. Extract the FSM + raw-event pipeline into injectable units (like the pure modules) and test them. Pre-broad-release."; :>> discoveredInField = false; :>> relatedTask = "round5CompletenessFollowups"; :>> severity = Severity::Medium; }
    part issueAdminReindex : Issue { :>> id = "c0f1a5cc-9706-4a10-9b20-a1b2c3d49706"; :>> title = "Corrupt-vault reindex is owner-only via curl; no admin surface for a shared/non-owned vault"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "Holistic#5 (LOW-MED, OPEN): reindex is registered only on the own-vault route (owner==caller) with no admin-UI button, so a shared vault that goes corrupt can be repaired only by its owner via a manual curl — the selfHostOperator persona wants an admin interface. Add an admin reindex route/button."; :>> discoveredInField = false; :>> relatedTask = "round5CompletenessFollowups"; :>> severity = Severity::Low; }
    part issueCommitCas : Issue { :>> id = "c0f1a5cc-9707-4a10-9b20-a1b2c3d49707"; :>> title = "No optimistic-concurrency on commit: exact-simultaneous double-first-commit on a shared vault loses an update"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "Adversary#3 (LOW, OPEN): if owner+grantee both read meta at the same base before either commits, both decide push; the write lock serializes them, the second overwrites the first, and the first committer later pulls (B===L → pull) with no conflict copy → lost edit. The common case is safe (the second committer normally sees R!=B → merge). Add expected_version/if-match to commit so a mismatch rejects and the client re-reconciles into a merge. Pre-broad-release for multi-writer shares."; :>> discoveredInField = false; :>> relatedTask = "round5CompletenessFollowups"; :>> severity = Severity::Low; }
    part issueDataMigration : Issue { :>> id = "c0f1a5cc-9708-4a10-9b20-a1b2c3d49708"; :>> title = "No explicit forward-migration path for client base/settings or the server index schema"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "Holistic#7 + GC-wording#6 (LOW, OPEN): loadSettings best-effort backfills but has no hook if the base map shape changes; the server Index has no version tag so any struct evolution forces CORRUPT→reindex. Also tighten the 'startup orphan GC' requirement wording to 'lazy first-access GC' (idle vaults GC on first open, not at boot). Related to the version handshake."; :>> discoveredInField = false; :>> relatedTask = "round5CompletenessFollowups"; :>> severity = Severity::Low; }
    part issueConflictCopyCosmetic : Issue { :>> id = "c0f1a5cc-9709-4a10-9b20-a1b2c3d49709"; :>> title = "Cosmetic conflict-copy edges: orphan copy if a streamed pull throws; tag can mismatch content on a racing save"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "Adversary#5 (cosmetic, OPEN): streamed conflictCopyIfRaced runs before streamFileToDisk, so if the stream then throws the conflict copy is orphaned (no overwrite); and the merge-fallback tags the copy name with the pre-fetch localHash, which no longer matches on a racing save. Neither loses data. Cleanup nicety."; :>> discoveredInField = false; :>> relatedTask = "round5CompletenessFollowups"; :>> severity = Severity::Low; }

