    // =====================================================================
    // ROUND 7 — recovery/operability + resource/scale critique (independent critics) vs 0.10.28,
    // 2026-07-07. Recovery bugs RC-2/3/4 fixed + shipped 0.10.28 (round7RecoveryFixes); RC-1 folds
    // into historyRebase; the resource/scale set (RS-1..7) is tracked under scaleHardening — the
    // scale-agnostic resolution is the storage-engine decision (SQLite recommended, pending).
    // =====================================================================
    part issueCorruptReindexResurrection : Issue { :>> id = "c0f1a5cc-9b01-4a10-9b20-a1b2c3d49b01"; :>> title = "Corrupt-index reindex drops ALL tombstones, resurrecting deleted files (recovery path induces loss)"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "RC-R7#1 (HIGH): a parse-corrupt index opens as Index::default() (empty deletions); reindex rebuilds files from disk but never restores tombstones (they existed only in the now-unparseable index), so changes(0) reports zero deletes and a long-offline client reads its since-deleted files as absence-without-tombstone -> RESTORES them (induced, user-perceived resurrection). The documented repair itself induces the resurrection Round 6 fixed for the cap case. Tombstones can't be reconstructed from disk, so the correct fix is the horizon + prompted-reconcile: a corrupt reindex IS a history reset. Folded into historyRebase."; :>> discoveredInField = false; :>> relatedTask = "historyRebase"; :>> severity = Severity::High; }
    part issueReindexBrick : Issue { :>> id = "c0f1a5cc-9b02-4a10-9b20-a1b2c3d49b02"; :>> title = "reindex aborts wholesale on one unrecoverable file -> permanent vault brick, shell-only escape"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "RC-R7#2 (HIGH): the DI-4 'refuse to drop indexed-but-missing files' guard becomes a brick when a file is genuinely gone (mirror-write failed AND chunk lost) — every reindex (owner or admin) aborts, the vault stays ERROR forever, escapable only by hand-deleting files in a shell. Fixed 0.10.28: reindex RECOVERS a missing-from-disk file from the authoritative chunk store where its chunks survive (the common failed-mirror case, no data loss); only truly-lost files abort, and an admin force drops them so the rest is repaired."; :>> discoveredInField = false; :>> relatedTask = "round7RecoveryFixes"; :>> severity = Severity::High; }
    part issueVaultGone404 : Issue { :>> id = "c0f1a5cc-9b03-4a10-9b20-a1b2c3d49b03"; :>> title = "A deleted/missing server vault shows as 'Can't reach the server — retrying' forever"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "RC-R7#3 (MED): doConnect distinguishes 401/version/not-ready but not 404 (vault-not-found), so a deleted/renamed server-side vault collapses into the catch-all connectivity message + indefinite backoff — the server IS reachable, the vault is gone, but the signal says the opposite. Fixed 0.10.28: a 404 surfaces 'this vault no longer exists — re-create or switch (local files untouched)'."; :>> discoveredInField = false; :>> relatedTask = "round7RecoveryFixes"; :>> severity = Severity::Medium; }
    part issueNoPerVaultDelete : Issue { :>> id = "c0f1a5cc-9b04-4a10-9b20-a1b2c3d49b04"; :>> title = "Operator toolkit gap: no per-vault delete (only whole-account) and no forced repair"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "RC-R7#4 (MED): the admin surface could create/reindex/share but not delete a single vault (only whole-account users_delete) nor force a repair past an unrecoverable file. Fixed 0.10.28: DELETE /api/admin/vault + admin-UI button (per-vault delete) and the forced reindex (RC-2). Residual (tracked): a UI to reset a latched client-side bulk-delete guard."; :>> discoveredInField = false; :>> relatedTask = "round7RecoveryFixes"; :>> severity = Severity::Medium; }
    part issueBasePersistConflict : Issue { :>> id = "c0f1a5cc-9b05-4a10-9b20-a1b2c3d49b05"; :>> title = "Client base-persist failure (full disk) -> stale base on reload -> spurious conflict copies"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "RC-R7#5 (LOW): persist() swallows a saveData error with a warning; the in-memory base advanced but data.json didn't, so a reload restores a stale base and files whose base was lost conflict-copy instead of merging cleanly (no data loss — the safe direction — but spurious copies + no clear cause). Tracked with the base-size/persistence robustness work (RS-4 area)."; :>> discoveredInField = false; :>> relatedTask = "scaleHardening"; :>> severity = Severity::Low; }
    part issueHandleNoEviction : Issue { :>> id = "c0f1a5cc-9b06-4a10-9b20-a1b2c3d49b06"; :>> title = "RS-1: VaultHandle map is never evicted — every vault ever opened stays fully resident in RAM"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "RS-R7#1 (scale): the ns map is only inserted-to (removed only on account delete) — no LRU/idle eviction, so a multi-vault server pins every touched vault's whole Index in RAM for process life (~40-60 MB per 100k-file vault). Storage-independent; needs idle-handle eviction. Tracked under scaleHardening."; :>> discoveredInField = false; :>> relatedTask = "scaleHardening"; :>> severity = Severity::Medium; }
    part issueIndexClonePerWrite : Issue { :>> id = "c0f1a5cc-9b07-4a10-9b20-a1b2c3d49b07"; :>> title = "RS-2: every commit/delete deep-clones the ENTIRE index for rollback (O(vault) per write)"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "RS-R7#2 (scale): commit/delete take `self.idx.clone()` (full deep copy of files+deletions+chunk_refs) purely for journal-failure rollback, so per-write cost grows with vault size — large vaults get slower to write regardless of change size. Mooted by the SQLite storage decision (row-level writes, no whole-index clone); until then, a targeted rollback would fix it. Tracked under scaleHardening."; :>> discoveredInField = false; :>> relatedTask = "scaleHardening"; :>> severity = Severity::Medium; }
    part issueFullReconcileOnRemote : Issue { :>> id = "c0f1a5cc-9b08-4a10-9b20-a1b2c3d49b08"; :>> title = "RS-3: reconcileAll re-pulls the whole manifest AND re-hashes the whole local vault on ANY remote change"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "RS-R7#3 (scale, mobile even at modest size): doReconcileAll fetches the incremental changes(since) then DISCARDS it and runs reconcileAll (changes(0) + full path-union rehash), so one remote edit re-hashes the entire local vault — seconds-to-minutes of CPU + battery on a large vault on a phone. Storage-independent: reconcile only the delta's paths on a remote poke; full pass only on the periodic config scan / version rewind. Tracked under scaleHardening (first to pull forward)."; :>> discoveredInField = false; :>> relatedTask = "scaleHardening"; :>> severity = Severity::Medium; }
    part issueBaseFullText : Issue { :>> id = "c0f1a5cc-9b09-4a10-9b20-a1b2c3d49b09"; :>> title = "RS-4: client base keeps the full TEXT of every mergeable file, re-serialized to data.json on every base change"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "RS-R7#4 (scale, mobile): setBase stores {hash,text} for every mergeable file, so base is a second full copy of all note text in RAM, and persist() stringifies the whole map on every base change -> a data.json the size of the vault, rewritten repeatedly. Storage-independent: cap per-file base text (large text -> hash-only, losing clean merge for those). Tracked under scaleHardening."; :>> discoveredInField = false; :>> relatedTask = "scaleHardening"; :>> severity = Severity::Medium; }
    part issueLinearChangesScan : Issue { :>> id = "c0f1a5cc-9b0a-4a10-9b20-a1b2c3d49b0a"; :>> title = "RS-5: changes(since) is an O(all files + all tombstones) linear scan run by every device every 4s"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "RS-R7#5 (scale): changes filters both collections by linear scan (no version index); every 4s idle poll from N devices is N x O(files+tombstones) for zero results, and the (now-durable, growing) tombstones make each poll ever more expensive. Mooted by SQLite (indexed WHERE version > ?). Tracked under scaleHardening."; :>> discoveredInField = false; :>> relatedTask = "scaleHardening"; :>> severity = Severity::Medium; }
    part issueFullSnapshotCost : Issue { :>> id = "c0f1a5cc-9b0b-4a10-9b20-a1b2c3d49b0b"; :>> title = "RS-6: snapshot re-serializes the whole index to one in-RAM JSON blob every 500 mutations"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "RS-R7#6 (scale): journal compaction serde_json::to_vec's the entire index (~50-100 MB for 100k files) under the write lock every 500 commits, stalling writers, and grows unbounded with tombstones. Mooted by SQLite (no full snapshot). Tracked under scaleHardening."; :>> discoveredInField = false; :>> relatedTask = "scaleHardening"; :>> severity = Severity::Low; }
    part issueColdOpenCost : Issue { :>> id = "c0f1a5cc-9b0c-4a10-9b20-a1b2c3d49b0c"; :>> title = "RS-7: cold-open does full deserialize + journal replay + chunk_refs recompute + list every blob"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "RS-R7#7 (scale): first access to a large vault deserializes the whole index, replays the journal, recomputes chunk_refs, and list_hashes() walks every blob dir (millions on a churny vault) — a multi-second-to-minutes stall. Amortized (lazy/rare), hence Low. Mooted by SQLite (no full deserialize; indexed integrity). Tracked under scaleHardening."; :>> discoveredInField = false; :>> relatedTask = "scaleHardening"; :>> severity = Severity::Low; }

