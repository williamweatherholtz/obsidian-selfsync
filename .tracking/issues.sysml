    // ---- UI functional-correctness audit (2026-07): 9 wiring defects found by tracing every control in
    // BOTH UIs end-to-end. All RESOLVED by the DONE, real-tested uiFunctionalAudit action. ----
    part issueUiSignoutNoRevoke : Issue { :>> id = "c0f1a5cc-b001-4a10-9b20-a1b2c3d4b001"; :>> title = "Admin A1: Sign out doesn't revoke the server session"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "Admin page 'Sign out' cleared only local sessionStorage; it never called POST /api/logout, so the bearer token stayed valid for its 30-day TTL. RESOLVED: signOut() now revokes server-side (best-effort). Class: discarded control effect."; :>> discoveredInField = false; :>> relatedTask = "uiFunctionalAudit"; :>> severity = Severity::High; }
    part issueUiMfaStaleIndicator : Issue { :>> id = "c0f1a5cc-b002-4a10-9b20-a1b2c3d4b002"; :>> title = "Admin A2: MFA panel shows 'disabled' after a successful enable"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "MFA confirm succeeded but never re-read status, so the panel kept the enroll/disabled view while the server was enabled. RESOLVED: confirm re-reads status (renderMfa) while preserving the one-time recovery codes. Class: dual-truth/stale indicator."; :>> discoveredInField = false; :>> relatedTask = "uiFunctionalAudit"; :>> severity = Severity::Medium; }
    part issueUiMustChangeDeadEnd : Issue { :>> id = "c0f1a5cc-b003-4a10-9b20-a1b2c3d4b003"; :>> title = "Admin A3: forced-change accounts bounce at login with no way in"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "Login ignored must_change_password; an admin-created/reset account stored a token, then /api/admin/me 403'd and the UI silently returned to login with no message and no change-password control. RESOLVED: a forced-change screen (POST /api/password). Class: dead-end dialog path."; :>> discoveredInField = false; :>> relatedTask = "uiFunctionalAudit"; :>> severity = Severity::High; }
    part issueUiOwnerVaultStale : Issue { :>> id = "c0f1a5cc-b004-4a10-9b20-a1b2c3d4b004"; :>> title = "Admin A4: owner-vault sub-row not reconciled after Repair/Delete"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "In the account→Vaults sub-row, Repair/Delete only set a message; the row wasn't re-fetched, so a deleted vault lingered and a repaired vault's health chip stayed stale. RESOLVED: the sub-row re-fetches + re-renders after each action. Class: stale indicator."; :>> discoveredInField = false; :>> relatedTask = "uiFunctionalAudit"; :>> severity = Severity::Medium; }
    part issueUiRepairMissing : Issue { :>> id = "c0f1a5cc-b005-4a10-9b20-a1b2c3d4b005"; :>> title = "Admin A5: Repair offered on a 'missing' vault where the endpoint 404s"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "The health chip called a 'missing' vault 'no data yet' but a Repair button was still shown; clicking it 404'd (reindex requires an existing vault). RESOLVED: Repair is gated to genuinely-degraded vaults in both panels. Class: dual-truth (chip vs action)."; :>> discoveredInField = false; :>> relatedTask = "uiFunctionalAudit"; :>> severity = Severity::Medium; }
    part issueUiWizardPassword : Issue { :>> id = "c0f1a5cc-b006-4a10-9b20-a1b2c3d4b006"; :>> title = "Plugin P1: setup wizard persists the plaintext password in token-only mode"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "finish() wrote st.password unconditionally AND set authToken, so freshLogin (the only place that clears the password when !storePassword) never ran — the plaintext password lingered in data.json against the token-only-at-rest default. RESOLVED: wizardCredentials() (pure, unit-tested) only persists it when storePassword. Class: security side-effect."; :>> discoveredInField = false; :>> relatedTask = "uiFunctionalAudit"; :>> severity = Severity::High; }
    part issueUiConfigToggleLatency : Issue { :>> id = "c0f1a5cc-b007-4a10-9b20-a1b2c3d4b007"; :>> title = "Plugin P2: config-sync toggles look inert (apply only on the ~2-min tick)"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "Config-sync master/category/plugin toggles only persisted + re-rendered; they took effect only on the next periodic config scan (up to CONFIG_SCAN_INTERVAL_MS ~2 min), so flipping one appeared to do nothing. RESOLVED: applyConfigSyncChange() forces a config scan and kicks a reconcile immediately. Class: switch appears inert."; :>> discoveredInField = false; :>> relatedTask = "uiFunctionalAudit"; :>> severity = Severity::Medium; }
    part issueUiLastSyncedPersist : Issue { :>> id = "c0f1a5cc-b008-4a10-9b20-a1b2c3d4b008"; :>> title = "Plugin P3: lastSyncedAt on the poll path not persisted"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "The poll path set settings.lastSyncedAt without saveSettings (the persist snapshot ran earlier in the pass), so 'Last synced' could lag after a restart. RESOLVED: explicit saveSettings on the poll path. Class: minor stale."; :>> discoveredInField = false; :>> relatedTask = "uiFunctionalAudit"; :>> severity = Severity::Low; }
    part issueUiLightVsWs : Issue { :>> id = "c0f1a5cc-b009-4a10-9b20-a1b2c3d4b009"; :>> title = "Plugin P4: status light shows green 'Fully synced' while the WebSocket is closed"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "The light was a pure projection of the reconcile FSM phase and never read ws.readyState; on a WS drop with polling still succeeding it stayed green 'Fully synced' though realtime was down. RESOLVED: a realtimeConnected flag threads into light() — idle-without-realtime is no longer green and says it's polling. Class: dual-truth (status vs transport)."; :>> discoveredInField = false; :>> relatedTask = "uiFunctionalAudit"; :>> severity = Severity::Medium; }
