    // =====================================================================
    // ROUND 2 — a THIRD fresh 3-lens adversarial critique (independent critics) against the
    // 0.10.17-hardened code, 2026-07-05. 16 NEW findings; 15 fixed + shipped 0.10.18
    // (#Resolves round2CriticFixes, done); several exposed GAPS in the Round-1 fixes themselves
    // (unverified cached chunks bypassing DI-2; stranded requeue from CONC#6; SEC#1 not covering
    // in-vault file paths). The 1 residual (large-file pull TOCTOU) is inherent + accepted.
    // =====================================================================
    part issueCacheUnverified : Issue { :>> id = "c0f1a5cc-9401-4a10-9b20-a1b2c3d49401"; :>> title = "Cached chunks bypassed DI-2 verification, laundering server bit-rot into a streamed file"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R2#1 (HIGH): fetchFileBytes cached chunks unverified and streamFileToDisk verified only on a cache MISS, so a corrupt blob cached during an aborted buffered fetch was trusted on a later dedup cache hit and re-pushed as canonical corruption. Fixed: getVerifiedChunk verifies before caching in both paths. +test."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::High; }
    part issuePullGapsStreamCreate : Issue { :>> id = "c0f1a5cc-9402-4a10-9b20-a1b2c3d49402"; :>> title = "DI-3 racing-edit guard missed the streamed branch and the racing-create case"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R2#2/#4: applyPull's guard ran only on the buffered path and only when the local file was present, so a large-file stream (or a racing local CREATE of an expected-absent path) silently clobbered local content. Fixed: shared conflictCopyIfRaced + guardRace flag covering both paths and the absent-expected case."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueMergeBaseDesync : Issue { :>> id = "c0f1a5cc-9403-4a10-9b20-a1b2c3d49403"; :>> title = "pushBytes discarded committed bytes; clean-merge base could record disagreeing (text,hash)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R2#3: the merge path set base from pre-write merged bytes while the hash came from pushFile's re-read — a racing save between them desynced base.text vs base.hash, poisoning the next merge's ancestor. Fixed: pushBytes returns PushResult; base recorded from committed bytes (DI-5 on the merge path)."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueConflictCopyStale : Issue { :>> id = "c0f1a5cc-9404-4a10-9b20-a1b2c3d49404"; :>> title = "Merge/conflict copies preserved the stale pre-fetch local read, not a racing edit"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R2#5: the merge/conflict-copy and read-only-share fallbacks wrote the localBytes read before the remote fetch as the conflict copy, so an edit made DURING the fetch was lost. Fixed: re-read current on-disk bytes for the copy. Also: bulk-delete ratio denominator now counts only accepted base paths (note)."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueDrainStranded : Issue { :>> id = "c0f1a5cc-9405-4a10-9b20-a1b2c3d49405"; :>> title = "A re-queued edit was stranded on the idle-poll short-circuit under a green light"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R2#1 (HIGH): onRemoteChanged's idle short-circuit returned before the drainPending() call, so a path re-queued by the CONC#6 fix was never retried while syncDone flipped the light green over the unsynced edit. Fixed: drainPending runs in the finally on every path."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::High; }
    part issueDirectOpNoRequeue : Issue { :>> id = "c0f1a5cc-9406-4a10-9b20-a1b2c3d49406"; :>> title = "A directly-attempted local op that failed was neither re-queued nor retried"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R2#2: onLocalEvent/Delete/Rename only logged on catch, relying on the next full reconcile; on an idle remote a transient failure left the edit unsynced for a long time. Fixed: re-queue the path(s) into pendingLocal on catch so the drain retries."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueVersionRewindPin : Issue { :>> id = "c0f1a5cc-9407-4a10-9b20-a1b2c3d49407"; :>> title = "Math.max version cursor pinned high after a server rewind, forcing a full reconcile every poll"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R2#3: reconcileAll/switchTo advanced the cursor with Math.max, so after a server reindex/restore rewound the version, every idle poll saw a mismatch and re-ran a full reconcile forever. Fixed: ASSIGN resp.version after a full reconcile (the client is consistent with it), so the incremental path converges."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueWsRedialRaces : Issue { :>> id = "c0f1a5cc-9408-4a10-9b20-a1b2c3d49408"; :>> title = "WS self-heal redial: stale-timer race, backoff inflation on lock-defer, expired-token redial storm"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R2#4/#5/#6: the CONC#3 redial could be armed by the old socket during a reconnect (racing it on failure); deferring reconnect for the applying lock doubled backoff toward the cap; a socket that never opened (expired token) re-dialed every 3s with the dead token. Fixed: reconnect cancels wsRedialTimer; lock-defer passes bumpBackoff=false; a never-opened socket escalates to a full reconnect."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Low; }
    part issueSelfFolderCase : Issue { :>> id = "c0f1a5cc-9409-4a10-9b20-a1b2c3d49409"; :>> title = "Case-sensitive self-folder exclusion let a shared vault overwrite the victim's SelfSync credentials"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R2#1 (MED, connection hijack): shouldSync compared the self-folder path case-sensitively while SEC#1 canonicalized only user/vault segments (not in-vault file paths), so a shared-vault owner committing .obsidian/plugins/NEW-LIVESYNC/data.json overwrote the victim's stored server URL+creds on a case-insensitive FS. Fixed: case-insensitive self-folder exclusion. +test."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueReindexJunkBrick : Issue { :>> id = "c0f1a5cc-940a-4a10-9b20-a1b2c3d4940a"; :>> title = "A committed junk-named file (.DS_Store/.git) permanently bricks reindex (cross-account)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R2#2: commit accepted names that reindex's collect_files skips as junk, so a later reindex counted them as 'indexed file missing from disk' (DI-4) and aborted every time — leaving the vault stuck in ERROR; a readWrite grantee could inflict it on the owner. Fixed: safe_rel_path rejects junk basenames. +test."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Medium; }
    part issueWsRevokeLeak : Issue { :>> id = "c0f1a5cc-940b-4a10-9b20-a1b2c3d4940b"; :>> title = "Share revocation didn't evict an in-flight WebSocket; revoked grantee kept getting change metadata"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R2#3: the WS authorized only at connect and never re-checked, so after share_delete the grantee's open socket kept receiving {type:changed,version} frames (content stays protected by per-request HTTP re-auth, but edit-timing + version counts leaked). Fixed: re-check the ACL before forwarding each notification; drop on revoke."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Low; }
    part issueAdminCreateArgon : Issue { :>> id = "c0f1a5cc-940c-4a10-9b20-a1b2c3d4940c"; :>> title = "Admin users_create bypassed the SEC-2 password cap + argon2 blocking-thread/semaphore"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R2#4: users_create hashed on the async runtime with no length cap, outside the auth_slots/spawn_blocking path (admin-gated, so low impact, matters more under ALLOW_WEAK_ADMIN=1). Fixed: enforce MAX_PASSWORD_LEN + run via the semaphore-bounded blocking path."; :>> discoveredInField = false; :>> relatedTask = "round2CriticFixes"; :>> severity = Severity::Low; }
    part issuePullTOCTOUResidual : Issue { :>> id = "c0f1a5cc-940d-4a10-9b20-a1b2c3d4940d"; :>> title = "Residual TOCTOU in the pull racing-edit check (edit landing between hash and write)"; :>> createdAt = "2026-07-05"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R2#7 / DI-adjacent (ACCEPT — inherent): the DI-3 disk re-check narrows but cannot fully close the window, since a local save can land between curHash and the final io.write; closing it entirely would require blocking Obsidian's own disk writes. Accepted as an inherent narrowing; the common cases are guarded."; :>> discoveredInField = false; :>> relatedTask = "residualLowFindings"; :>> severity = Severity::Low; }

    #Resolves dependency from round2CriticFixes to issueCacheUnverified;
    #Resolves dependency from round2CriticFixes to issuePullGapsStreamCreate;
    #Resolves dependency from round2CriticFixes to issueMergeBaseDesync;
    #Resolves dependency from round2CriticFixes to issueConflictCopyStale;
    #Resolves dependency from round2CriticFixes to issueDrainStranded;
    #Resolves dependency from round2CriticFixes to issueDirectOpNoRequeue;
    #Resolves dependency from round2CriticFixes to issueVersionRewindPin;
    #Resolves dependency from round2CriticFixes to issueWsRedialRaces;
    #Resolves dependency from round2CriticFixes to issueSelfFolderCase;
    #Resolves dependency from round2CriticFixes to issueReindexJunkBrick;
    #Resolves dependency from round2CriticFixes to issueWsRevokeLeak;
    #Resolves dependency from round2CriticFixes to issueAdminCreateArgon;
