    #Resolves dependency from critResidual2 to issueCmmc2AuditSource;         // DONE (privileged-denial half real-tested; read-denial remainder accepted/proxy-correlated)
    #Resolves dependency from critResidualEasy to issueCmmc2MobileCodeWording; // DONE

    // ---- Client-audit follow-up (2026-07-12): a dual-source sweep of the SERVER, prompted after the
    // client conflict-model re-architecture (D0024). One LOW cross-store ordering defect found + fixed;
    // the rest verified clean (share membership is a single list, chunk refcounts are computed by query
    // not stored, the version epoch is irreducibly stored — all safe by construction). ----
    part issueShareLinkBurnedOnFailedGrant : Issue { :>> id = "c0f1a5cc-e001-4a10-9b20-a1b2c3d4e001"; :>> title = "Share-link redeem consumes the single-use link before the grant is secured (a failed grant burns the invite)"; :>> createdAt = "2026-07-12"; :>> createdBy = "wweatherholtz"; :>> description = "share_link_redeem marked the link consumed + fsynced (.share-links.json) BEFORE minting the grant (.shares.json) — two stores, two writes, no shared lock. If the follow-on grant then failed for a recoverable reason (owner at MAX_GRANTS_PER_OWNER, or a grant I/O error), or the process crashed between the two writes, the single-use link was permanently burned with NO grant created: the invitee had no access and the owner had to mint a fresh link. redeemed_by never feeds an authz decision (authorized() reads only the Grant), so it fails CLOSED — availability/correctness, not security or data-integrity. RESOLVED (1.0.30 server): redeem still CLAIMS the link atomically first (preserving single-use under concurrency), but the handler now rolls the claim back via ShareLinkStore::unredeem on both recoverable failure branches, so the invite survives to be retried; only the narrow crash-between-two-file-writes window remains (accepted — far narrower than the prior any-cap/any-error window). Test: sharelinks unredeem_rolls_back_a_claim_so_a_failed_grant_does_not_burn_the_link. Found by the client-audit-driven server dual-source sweep. Class: cross-store non-atomic write."; :>> discoveredInField = false; :>> relatedTask = "shareLinkRedeemConsumeLast"; :>> severity = Severity::Low; }
    #Resolves dependency from shareLinkRedeemConsumeLast to issueShareLinkBurnedOnFailedGrant;

    // ---- 3-lens adversarial critique of the session's shipped code (conflict re-arch D0024 + 1.0.30
    // client/server fixes), 2026-07-12, triggered by a FIELD report of a read-only vault still
    // false-flagging conflicts. Independent critics (correctness / security / concurrency); every
    // finding below verified against the code by the author before recording. All ACT except the
    // accepted redeem-cap oracle (informational, not modeled). ----
    part issueFalseConflictReadOnlyBinary : Issue { :>> id = "c0f1a5cc-f001-4a10-9b20-a1b2c3d4f001"; :>> title = "Read-only shared vault manufactures unsyncable, permanently-flagged conflict copies for a no-base divergence (FIELD)"; :>> createdAt = "2026-07-12"; :>> createdBy = "wweatherholtz"; :>> description = "FIELD-REPORTED: a read-only shared vault kept false-flagging conflicts. Root cause: reconcile's conflict-copy branch fired on read-only for a NO-COMMON-BASE divergence (decide()'s conservative default, not a real reader edit). A binary attachment (PNG) present on both the reader and the owner with differing bytes and no base → conflict-copy → the read-only branch wrote a local '(conflict …)' copy. On a read-only share that copy can NEVER push, so it's permanent litter: deriveNoteConflicts flags it forever AND it fires 'local change won't sync' every reconcile (the reported log line's path was the copy itself). RESOLVED (1.0.31): on read-only, only preserve a copy for a genuine both-sides edit against a KNOWN base (action 'merge'); a no-base divergence adopts the owner's bytes with NO copy. Also: the push case no longer reports an existing conflict-copy file as 'won't sync' (it's deliberately local). Class: false-positive conflict / read-only semantics."; :>> discoveredInField = true; :>> relatedTask = "conflictReadOnlyAndBinaryCorrectness"; :>> severity = Severity::High; }
    part issueCosmeticGuardBinaryClobber : Issue { :>> id = "c0f1a5cc-f002-4a10-9b20-a1b2c3d4f002"; :>> title = "sameIgnoringEol / cosmeticEqual lossy-decode BINARY → two different attachments collapse to equal → silent local data loss"; :>> createdAt = "2026-07-12"; :>> createdBy = "wweatherholtz"; :>> description = "Correctness critic (High). The cosmetic-EOL guard (reconcile.ts) and the modal auto-dismiss (noteconflict.ts) normalized via a NON-fatal TextDecoder, which maps every invalid byte to U+FFFD. Two genuinely different binary blobs whose differing bytes are both invalid UTF-8 normalize to the SAME string → the guard adopts remote over local with NO conflict copy (reconcile), or the modal auto-deletes this device's only copy — silent data loss for attachments, the exact 'never clobber on divergence' invariant the module protects. RESOLVED (1.0.31): both loci gate the cosmetic check on isMergeable(path,bytes) (extension- AND fatal-UTF-8-gated), so binary / invalid-UTF-8 content is excluded and can never be lossy-collapsed; genuine text keeps the false-EOL fix. Test: reconcile 'NO-BASE BINARY divergence keeps BOTH — never lossy-collapsed'. Class: data-integrity (silent clobber)."; :>> discoveredInField = false; :>> relatedTask = "conflictReadOnlyAndBinaryCorrectness"; :>> severity = Severity::High; }
    part issueGrantSaveRollback : Issue { :>> id = "c0f1a5cc-f003-4a10-9b20-a1b2c3d4f003"; :>> title = "shares.rs grant() leaves an in-memory grant when its save() fails → redeem rollback breaks single-use"; :>> createdAt = "2026-07-12"; :>> createdBy = "wweatherholtz"; :>> description = "Concurrency critic (Medium). grant() mutated self.file.grants then save()'d; on a save I/O error (disk full/EIO) the in-memory grant persisted while only Err was returned. The redeem handler, which unredeems (restores the link) on grant Err, then left BOTH a live in-memory grant AND a re-redeemable single-use link — violating single-use and the 'fails closed' contract. RESOLVED (server): grant() snapshots grants, mutates, saves, and restores the snapshot on save failure so in-memory always matches the last durable state. Test: shares grant_rolls_back_in_memory_when_save_fails. Class: cross-store consistency under I/O failure."; :>> discoveredInField = false; :>> relatedTask = "shareRedeemStoreConsistency"; :>> severity = Severity::Medium; }
    part issueSelfRedeemBurnsLink : Issue { :>> id = "c0f1a5cc-f004-4a10-9b20-a1b2c3d4f004"; :>> title = "Share-link self-redeem (owner redeems own link) burns the single-use invite (contradicts documented no-op)"; :>> createdAt = "2026-07-12"; :>> createdBy = "wweatherholtz"; :>> description = "Correctness + security critics (Medium). redeem() claims (consumes) the link before the owner==user check; the self-redeem branch skipped the grant AND the unredeem, returning success with the link consumed — so an owner testing their own link destroyed it for the intended recipient, contradicting the handler's 'self-redeem is a no-op success' comment. RESOLVED (server): the owner==user branch now unredeems (releases the claim), leaving the invite redeemable. Test: admin self_redeem_does_not_burn_the_link. Class: availability / single-use."; :>> discoveredInField = false; :>> relatedTask = "shareRedeemStoreConsistency"; :>> severity = Severity::Medium; }
    part issueResolveMineToctou : Issue { :>> id = "c0f1a5cc-f005-4a10-9b20-a1b2c3d4f005"; :>> title = "resolveNoteConflict 'keep mine' TOCTOU — stale-preview guard, then two awaits before the write → a reconcile can be clobbered"; :>> createdAt = "2026-07-12"; :>> createdBy = "wweatherholtz"; :>> description = "Concurrency critic (Medium). 'keep mine' checked the stale-preview guard, then yielded twice (io.exists, io.read) before writing original; the modal runs OUTSIDE the engine queue, so a poll-driven reconcile could pull a newer original into that gap and get silently overwritten + pushed. RESOLVED (1.0.31): re-check original===previewedOther immediately before the write (no await between the re-check and the write), narrowing the window to nothing actionable. Class: data-loss (narrow race)."; :>> discoveredInField = false; :>> relatedTask = "conflictReadOnlyAndBinaryCorrectness"; :>> severity = Severity::Medium; }
    part issueUnloadPollLeak : Issue { :>> id = "c0f1a5cc-f006-4a10-9b20-a1b2c3d4f006"; :>> title = "unload during in-flight connect() leaks a poll interval (startPolling has no unloading guard; widened by the 1.0.30 refreshShareGrant await)"; :>> createdAt = "2026-07-12"; :>> createdBy = "wweatherholtz"; :>> description = "Concurrency critic (Low-Med). unload is handled synchronously and can run while connect() is suspended at an await; on resume spinUpWs early-returns (guarded) but startPolling did not, installing a fresh setInterval that outlives teardown and pins the plugin (one leaked timer per disable/re-enable). The 1.0.30 refreshShareGrant await added a full round-trip to this window, materially widening it. RESOLVED (1.0.31): startPolling returns early when unloading (matches spinUpWs). Class: resource leak on unload (regression-adjacent)."; :>> discoveredInField = false; :>> relatedTask = "conflictReadOnlyAndBinaryCorrectness"; :>> severity = Severity::Low; }
    part issueConflictCopyLookalikeDelete : Issue { :>> id = "c0f1a5cc-f007-4a10-9b20-a1b2c3d4f007"; :>> title = "A user note literally named like a conflict copy is flagged and can be offered as a deletable version"; :>> createdAt = "2026-07-12"; :>> createdBy = "wweatherholtz"; :>> description = "Correctness critic (Low). originalOfConflictCopy matches any stem ending ' (conflict <name> <14 digits>)'; a user could craft one. deriveNoteConflicts would surface it, and if the derived 'original' doesn't exist, the modal could offer the user's real note as a deletable copy. RESOLVED (1.0.31): listNoteConflicts now requires the derived original to EXIST in the vault — a genuine conflict copy always sits beside its original; an orphan/look-alike isn't flagged. Also reduces false-flagging generally. Class: false-positive / accidental delete."; :>> discoveredInField = false; :>> relatedTask = "conflictReadOnlyAndBinaryCorrectness"; :>> severity = Severity::Low; }
    part issueShareGrantFailOpen : Issue { :>> id = "c0f1a5cc-f008-4a10-9b20-a1b2c3d4f008"; :>> title = "resolveShareGrant fails OPEN for an unknown perm string (defaults to read-write)"; :>> createdAt = "2026-07-12"; :>> createdBy = "wweatherholtz"; :>> description = "Correctness critic (Low). readOnly = perm==='read' meant any value that isn't exactly 'read' (a future/renamed/malformed perm) yielded read-write — the wrong default direction for a security flag (server enforcement still prevents actual unauthorized writes, hence Low). RESOLVED (1.0.31): readOnly = perm!=='readWrite' — fails closed (read-only unless explicitly readWrite). Test: sharelink 'fails CLOSED — unknown/malformed perm is read-only'. Class: fail-open default (defense-in-depth)."; :>> discoveredInField = false; :>> relatedTask = "conflictReadOnlyAndBinaryCorrectness"; :>> severity = Severity::Low; }
    #Resolves dependency from conflictReadOnlyAndBinaryCorrectness to issueFalseConflictReadOnlyBinary;
    #Resolves dependency from conflictReadOnlyAndBinaryCorrectness to issueCosmeticGuardBinaryClobber;
    #Resolves dependency from conflictReadOnlyAndBinaryCorrectness to issueResolveMineToctou;
    #Resolves dependency from conflictReadOnlyAndBinaryCorrectness to issueUnloadPollLeak;
    #Resolves dependency from conflictReadOnlyAndBinaryCorrectness to issueConflictCopyLookalikeDelete;
    #Resolves dependency from conflictReadOnlyAndBinaryCorrectness to issueShareGrantFailOpen;
    #Resolves dependency from shareRedeemStoreConsistency to issueGrantSaveRollback;
    #Resolves dependency from shareRedeemStoreConsistency to issueSelfRedeemBurnsLink;

    // ---- Field follow-up (2026-07-12): a mobile resume before DNS was ready flooded the log with
    // ~200 per-file UnknownHostException errors — a whole-connection failure isolated per-file. ----
    part issueConnErrorPerFileFlood : Issue { :>> id = "c0f1a5cc-f009-4a10-9b20-a1b2c3d4f009"; :>> title = "A connection-level failure (DNS unresolvable) is isolated per-file, flooding the log with one error per file instead of aborting the pass"; :>> createdAt = "2026-07-12"; :>> createdBy = "wweatherholtz"; :>> description = "FIELD: on mobile resume (app switched away → the OS suspended the app + dropped the network), reconcile started before DNS was ready and every file's pull threw the SAME UnknownHostException; the per-file error isolation (meant for one bad file while the rest continue) caught each and continued, logging ~200 identical 'couldn't sync … No address associated with hostname' lines and churning the whole vault pointlessly. It's a connectivity-timing condition (not a sync-logic bug), but the handling turned one outage into a flood + wasted battery. RESOLVED (1.0.33): a new isConnectionError classifier (host-resolution + connection-refused/reset/unreachable — deliberately NOT per-file content/read errors) makes the reconcileAll / reconcileDelta / config loops ABORT the pass on the first connection error (a shared connAbort flag short-circuits the remaining files) → the engine goes offline + backs off ONCE. A genuine single-file error (corrupt chunk, locked file, full disk) still isolates. Tests: reconcile 'a CONNECTION failure (DNS) ABORTS the pass — one error, not one-per-file' + 'single-file error is still ISOLATED' + isConnectionError boundary cases. Class: error-handling (connection-level vs per-file)."; :>> discoveredInField = true; :>> relatedTask = "connErrorAbortsPass"; :>> severity = Severity::Low; }
    #Resolves dependency from connErrorAbortsPass to issueConnErrorPerFileFlood;

    part issueEditorStatusIconLeakOnReload : Issue { :>> id = "c0f1a5cc-f00a-4a10-9b20-a1b2c3d4f00a"; :>> title = "In-editor sync icon (view.addAction) isn't removed on unload → every plugin update stacks another stale icon in the note header"; :>> createdAt = "2026-07-12"; :>> createdBy = "wweatherholtz"; :>> description = "FIELD: the note header showed SIX sync icons (one green check + five red triangles). Root cause: the opt-in in-editor indicator is added via view.addAction, which — unlike addRibbonIcon / addStatusBarItem — Obsidian does NOT auto-remove when a plugin unloads, and onunload didn't remove it either. So every plugin RELOAD/UPDATE (~5 today) orphaned the prior instance's header icon and the new instance added another; the dead ones froze at their last-rendered phase (green=synced, red=offline). Within one run it was already idempotent (an editorViews WeakSet guard); the leak was purely across reloads. RESOLVED (1.0.34): onunload removes all editorActionEls (mirrors the existing setEditorStatus-off cleanup), so unload leaves nothing behind and the next load shows exactly one icon. Orphans from pre-1.0.34 updates clear on a one-time Obsidian restart. Class: lifecycle/resource leak (non-idempotent add across reloads)."; :>> discoveredInField = true; :>> relatedTask = "editorStatusCleanupOnUnload"; :>> severity = Severity::Low; }
    #Resolves dependency from editorStatusCleanupOnUnload to issueEditorStatusIconLeakOnReload;

    // ---- UI/UX critique pass (2026-07-13, 3 independent lens critics: IA / copy / flows). Findings
    // verified against the code before recording; ≥Medium dispositioned ACT by wweatherholtz (chose all
    // four fix buckets). Split across releases 1.3.1 (polish) / 1.3.2 (destructive guards) / 1.4.0
    // (plugin-adoption ending) / 1.5.0 (sharing+conflicts surfacing). ----
    part issueUxQuickWins : Issue { :>> id = "c0f1a5cc-e00a-4a10-9b20-a1b2c3d4e00a"; :>> title = "UX polish: misdirecting recovery copy, jammed consent banner, silent max-file-size failure, inconsistent terminology + dead code"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "UX critique quick-win bundle. (HIGH) The session-expired / vault-gone recovery messages told the user to 'use Set up / switch vault' — a COMMAND name, not a button; the real buttons are 'Reconfigure' and 'Switch' — misdirecting exactly when stuck. (MED) The setup server/consent banner used \\n\\n in a <p> with no white-space:pre-wrap, collapsing the compliance banner to one run-on line. (MED) 'Max file size' invalid/empty input failed SILENTLY — no save, no message, no revert. (MED) A broken breadcrumb: a log line pointed to 'Settings → Config differences', a section that doesn't exist (it's 'Conflicts'). (LOW) 3 log-viewer toasts dropped the 'SelfSync:' prefix; 'Keep the other' had no referent; 'reload Obsidian' is undefined on mobile; change-password didn't warn other token-only devices need the NEW password; statusTitle() was dead code diverged from statusDisplay(). RESOLVED (1.3.1): recovery copy names the real buttons; banner gets pre-wrap; max-file-size validates on blur (notice + revert); breadcrumb → 'Conflicts'; toast prefixes fixed; 'Keep the other device's'; 'fully close and reopen Obsidian'; change-password warning extended; statusTitle + its test removed. Class: copy/feedback/clarity."; :>> discoveredInField = false; :>> relatedTask = "uxPolishBundle"; :>> severity = Severity::Medium; }
    #Resolves dependency from uxPolishBundle to issueUxQuickWins;

    part issueUnguardedDestructiveActions : Issue { :>> id = "c0f1a5cc-e00b-4a10-9b20-a1b2c3d4e00b"; :>> title = "Irreversible actions (mirror-switch delete, fork-overwrite, sign-out) are less guarded than harmless ones"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "UX critique (flows lens), HIGH. The plugin guarded SAFE actions but under-guarded IRREVERSIBLE ones: (1) the vault-switch 'Download'/'Upload' mirror modes DELETE local-only / remote-only files on a single warning-styled tap with no confirmation — while the non-destructive 'Leave share' has a full confirm(); (2) Fork uploads unconditionally (skips the switch resolve-prompt), so a fork name that already matches an owned vault would OVERWRITE it with no check; (3) 'Sign out' (token-only mode → no saved password) sits next to 'Change password' with no confirm, easy to fat-finger, and strands the user needing their password. RESOLVED (1.3.2): applySwitch confirm()s Download/Upload naming which side loses files ('can't be undone'); doFork refuses/confirms when the name already exists (checks the loaded vault list); Sign out confirm()s ('you'll need your password to sign back in; local files kept'). Merge (safe) still needs no confirm. Class: destructive-action guarding / data-safety."; :>> discoveredInField = false; :>> relatedTask = "guardDestructiveActions"; :>> severity = Severity::High; }
    #Resolves dependency from guardDestructiveActions to issueUnguardedDestructiveActions;

    part issuePluginAdoptionSilentRestart : Issue { :>> id = "c0f1a5cc-e00c-4a10-9b20-a1b2c3d4e00c"; :>> title = "Plugin adoption ends in an invisible restart requirement; a fresh vault's empty plugin list reads as 'nothing to sync'"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "UX critique (all 3 lenses), HIGH. After 'Install all from the sync', the settings pane re-renders showing the plugins as synced, but nothing is active: files download on the next reconcile and Obsidian only loads plugins at STARTUP, so they stay dormant until a full restart — the only hint was a transient async toast saying 'reload Obsidian' (meaningless on mobile). Looks done, isn't → users re-tap or conclude it failed. Separately, on a fresh vault before the first reconcile reports server plugins, the checklist was EMPTY and read as 'nothing to sync' (the list populates minutes later). RESOLVED (1.4.0): a STANDING banner in the Synced-community-plugins group counts plugins adopted-but-not-installed-locally and says 'fully close and reopen Obsidian (on mobile, swipe the app away) to enable them'; and a 'Checking the server for plugins…' placeholder shows while the server list is still empty. Class: silent-until-later step / discoverability."; :>> discoveredInField = false; :>> relatedTask = "pluginAdoptionRestartHint"; :>> severity = Severity::High; }
    #Resolves dependency from pluginAdoptionRestartHint to issuePluginAdoptionSilentRestart;

    part issueSharingConflictsDiscoverability : Issue { :>> id = "c0f1a5cc-e00d-4a10-9b20-a1b2c3d4e00d"; :>> title = "Inbound sharing + conflicts are undiscoverable; redeem-while-signed-in ends in a toast that syncs nothing"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "UX critique (IA + flows). Redeeming a share link — the primary INBOUND action — was reachable only by opening a button labelled 'Switch' and scrolling; a new recipient had no labelled path at all. Conflicts (data-safety, urgent) had no command/ribbon surface — only the transient toast + a settings section that exists only when conflicts are pending. And an already-signed-in redeem added the grant but relied on a 9s toast ('Open Settings → Switch vault to sync it') then synced NOTHING — easy to miss on mobile, so redeem looked like it did nothing. RESOLVED (1.5.0): added command-palette commands 'Switch vault', 'Redeem a share link', and 'Resolve conflicts' (routes to whichever kind is pending), renamed the setup command to 'Set up / reconfigure connection'; added a 'Redeem a share link' button to the unconfigured status card (the new-recipient entry point); and startRedeem now OPENS the Switch modal after an already-signed-in redeem (the redeemed vault is in its 'Shared with you' list) instead of leaving the second step to a toast. Class: discoverability / silent-until-later step."; :>> discoveredInField = false; :>> relatedTask = "surfaceSharingAndConflicts"; :>> severity = Severity::Medium; }
    #Resolves dependency from surfaceSharingAndConflicts to issueSharingConflictsDiscoverability;

    // ---- UX-critique findings the user DECLINED to act on now (2026-07-13, "record these as declined
    // items"). Real but larger; deferred by an explicit human disposition (deferUxEnhancements). ----
    part issueNoProtocolHandler : Issue { :>> id = "c0f1a5cc-e00e-4a10-9b20-a1b2c3d4e00e"; :>> title = "No obsidian:// protocol handler — tapped share/setup links can't deep-link into the flow"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "UX critique (IA lens), Medium. The plugin registers no registerObsidianProtocolHandler; share/setup payloads use bespoke selfsync:// / selfsync-share:// schemes the OS won't route into Obsidian, so every hand-off degrades to copy-paste. Fix would register an obsidian://selfsync?… handler that opens the setup-or-redeem flow prefilled, and re-encode payloads as obsidian:// URLs (keeping copyable text as fallback). DECLINED for now (larger change; deferred by wweatherholtz 2026-07-13). Class: onboarding friction (deferred)."; :>> discoveredInField = false; :>> relatedTask = "deferUxEnhancements"; :>> severity = Severity::Medium; }
    part issueWizardStatePersistence : Issue { :>> id = "c0f1a5cc-e00f-4a10-9b20-a1b2c3d4e00f"; :>> title = "Setup-wizard state is in-memory only — a mid-flow suspend can orphan a just-registered account"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "UX critique (flows lens), Medium. The wizard keeps server/username/password/token in memory and persists only on finish; on mobile a suspend after 'Create account' registers the account server-side but reopening starts blank, so a second create attempt errors confusingly. Fix would persist wizard progress (at least server+username+registered-flag+token) or transition to a persisted logged-in state right after register. DECLINED for now (non-trivial; deferred by wweatherholtz 2026-07-13). Class: re-entrancy / mobile-suspend (deferred)."; :>> discoveredInField = false; :>> relatedTask = "deferUxEnhancements"; :>> severity = Severity::Medium; }
    part issueDeepIaRestructure : Issue { :>> id = "c0f1a5cc-e010-4a10-9b20-a1b2c3d4e010"; :>> title = "Deeper IA restructures deferred: overlapping connection verbs + a unified Vaults & sharing surface"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "UX critique (IA lens), Low-Medium. Two structural items beyond the 1.3–1.5 fixes: (a) three overlapping stop/change-connection verbs (Sign out / Disconnect / Reconfigure) split across sections with a disambiguating paragraph — should be one clearer model; (b) inbound vs outbound sharing split across 'Share' and 'Switch' — a single 'Vaults & sharing' surface would unify 'shared with me' (redeem/leave) and 'people I share with' (grants/links). 1.5.0 added redeem/switch/resolve COMMANDS + a redeem button, which mitigates discoverability, but the deeper consolidation is DECLINED for now (deferred by wweatherholtz 2026-07-13). Also folds the residual UX lows the user didn't select (conflict-modal nested scroll + destructive default; 'Install all' label flip). Class: information architecture (deferred)."; :>> discoveredInField = false; :>> relatedTask = "deferUxEnhancements"; :>> severity = Severity::Low; }
    #Resolves dependency from deferUxEnhancements to issueNoProtocolHandler;
    #Resolves dependency from deferUxEnhancements to issueWizardStatePersistence;
    #Resolves dependency from deferUxEnhancements to issueDeepIaRestructure;

    // ---- Human-factors critique pass (2026-07-13, independent HF/cognitive-ergonomics expert). Findings
    // verified against the code; ≥Medium dispositioned ACT by wweatherholtz (all four buckets). ----
    part issueStatusIndicatorMisleads : Issue { :>> id = "c0f1a5cc-e011-4a10-9b20-a1b2c3d4e011"; :>> title = "Status indicator misleads: green 'Fully synced' on a read-only vault, and one yellow SPINNER covers healthy-polling + connecting + syncing"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "HF critique, HIGH (gulf of evaluation / mode error / alarm habituation). (F1) On a read-only shared vault Obsidian still lets the user EDIT, but those edits never upload — yet statusDisplay's idle branch showed a plain green 'Fully synced', implying the user's changes are safe on the server (they're stranded or overwritten). (F3) idle-over-polling rendered the SAME yellow refresh-cw SPINNER as connecting/syncing, so a healthy device on a dropped websocket sat at a permanent spinner — indistinguishable from 'stuck', training panic or habituation. RESOLVED (1.5.1): idle on a read-only vault reads 'Synced (read-only) — your edits stay on this device' with a lock glyph; idle (realtime OR polling) now uses a STEADY glyph (check/lock), never the spinner — the spinner is reserved for the active connecting/syncing states; colour still distinguishes green vs yellow. Test: plugin-wiring statusDisplay read-only case. Class: status legibility / mode error."; :>> discoveredInField = false; :>> relatedTask = "hfStatusAndWarnings"; :>> severity = Severity::High; }
    part issueMiscalibratedSwitchWarning : Issue { :>> id = "c0f1a5cc-e012-4a10-9b20-a1b2c3d4e012"; :>> title = "Vault-switch download warning cried 'can't be undone', but local removals go to the recoverable vault trash"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "HF critique, Low-Med (Nielsen #9 / warning calibration). The 1.3.2 download confirm said local files 'will be DELETED from this device. This can't be undone.' — but ObsidianVaultIo.remove routes sync-driven deletions to the vault trash (recoverable). Over-warning on a recoverable action erodes the credibility of 'can't be undone' where it IS true (server upload). RESOLVED (1.5.1): download confirm now says local files are 'moved to this device's trash (recoverable there)'; upload says 'removed on the server'; dropped the blanket 'can't be undone'. Class: warning calibration."; :>> discoveredInField = false; :>> relatedTask = "hfStatusAndWarnings"; :>> severity = Severity::Low; }
    #Resolves dependency from hfStatusAndWarnings to issueStatusIndicatorMisleads;
    #Resolves dependency from hfStatusAndWarnings to issueMiscalibratedSwitchWarning;

    part issueSidePickingInconsistent : Issue { :>> id = "c0f1a5cc-e013-4a10-9b20-a1b2c3d4e013"; :>> title = "Four 'pick a side' surfaces use inconsistent wording + a biasing CTA on the unbiased note-conflict choice"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "HF critique, Med (mental-model instability + capture error). The same 'which side wins?' decision was worded differently across note-conflict / config-conflict / config-direction / vault-switch, and the CTA (highlighted default) jumped sides — worst, the note-conflict highlighted 'Keep this device's' on a genuinely 50/50 IRREVERSIBLE content choice, inviting a reflexive tap that discards the other device's edits. RESOLVED (1.5.2): removed the CTA from the unbiased destructive choices (note-conflict + config-conflict); standardized config vocabulary to 'Use this device's' / 'Use the synced version'; CTA now reserved for a genuinely-safe default (vault-switch Merge). Class: mental-model consistency / capture-error prevention."; :>> discoveredInField = false; :>> relatedTask = "hfConfirmAndSidePicking"; :>> severity = Severity::Medium; }
    part issueNativeConfirmMobile : Issue { :>> id = "c0f1a5cc-e014-4a10-9b20-a1b2c3d4e014"; :>> title = "Destructive guards used native window.confirm() — out-of-context / unstyled on the mobile Capacitor webview"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "HF critique, Low (consistency / error-prevention trust). The confirmations added in 1.3.2 (mirror-switch, fork-overwrite, leave-share, sign-out) used window.confirm(), which on Obsidian mobile renders as a bare OS dialog divorced from the plugin's visual context — reading as less trustworthy exactly at a destructive step. RESOLVED (1.5.2): a small in-app ConfirmModal (confirm.ts, confirmModal()) consistent with the plugin's other modals replaces all four confirm() calls (warn-styled confirm button, named consequence). Class: consistency / confirmation reliability."; :>> discoveredInField = false; :>> relatedTask = "hfConfirmAndSidePicking"; :>> severity = Severity::Low; }
    #Resolves dependency from hfConfirmAndSidePicking to issueSidePickingInconsistent;
    #Resolves dependency from hfConfirmAndSidePicking to issueNativeConfirmMobile;

    part issueMobileStatusTextless : Issue { :>> id = "c0f1a5cc-e015-4a10-9b20-a1b2c3d4e015"; :>> title = "On mobile the only persistent status is a textless icon in the sidebar drawer with no reachable tooltip"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "HF critique, High (gulf of evaluation / Nielsen #1). Mobile gets a ribbon icon only; the informative text lives in an aria-label (no touch tooltip) and the settings card — so 'did my note sync?' takes 2-3 taps on the platform whose goal is glanceable. PARTIALLY RESOLVED (1.6.0): added a 'Sync status' command that toasts the current status text (a one-tap words readout, works on mobile). NOTE: a truly persistent on-screen TEXT indicator isn't available — Obsidian mobile has no status bar and view.addAction is icon-only; the opt-in in-editor indicator (glanceable colour at the note) remains the persistent option. Class: status legibility (platform-limited; partially mitigated)."; :>> discoveredInField = false; :>> relatedTask = "hfStatusSurfacingAndPreview"; :>> severity = Severity::High; }
    part issueBlindConfigOverwrite : Issue { :>> id = "c0f1a5cc-e016-4a10-9b20-a1b2c3d4e016"; :>> title = "Config first-contact direction is a whole-side overwrite with no preview, unlike the diff-showing conflict screens"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "HF critique, Med (gulf of evaluation before commit). Turning on a config surface asks download/upload but shows nothing about what will change, while the more-recoverable per-file conflict shows a diff. PARTIALLY RESOLVED (1.6.0): the ConfigDirectionModal copy now sets expectations — 'only files that differ change, everything else is left alone, and later edits on either side reconcile normally'. NOTE: a true diff/count preview needs a local-vs-server compare the modal doesn't have; deferred as a possible follow-up. Class: pre-commit evaluation (copy-level mitigation)."; :>> discoveredInField = false; :>> relatedTask = "hfStatusSurfacingAndPreview"; :>> severity = Severity::Medium; }
    part issueLongOpTransientCompletion : Issue { :>> id = "c0f1a5cc-e017-4a10-9b20-a1b2c3d4e017"; :>> title = "Fork/switch report progress only via a transient toast, lost when the app suspends"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "HF critique, Med (gulf of evaluation for long ops). A fork/switch that uploads a whole vault can run for minutes; the modal closes and completion is a toast that fires into a suspended app, with only a generic yellow 'syncing' meanwhile — the user can't tell if it finished. RESOLVED (1.6.0): statusDisplay shows a persistent 'Switching vault…' state whenever a switch/fork is in flight, DERIVED from the saved pendingSwitch flag, so it survives suspend/resume and clears when the switch reconcile completes. Test: plugin-wiring statusDisplay pendingSwitch case. Class: long-op evaluation."; :>> discoveredInField = false; :>> relatedTask = "hfStatusSurfacingAndPreview"; :>> severity = Severity::Medium; }
    #Resolves dependency from hfStatusSurfacingAndPreview to issueMobileStatusTextless;
    #Resolves dependency from hfStatusSurfacingAndPreview to issueBlindConfigOverwrite;
    #Resolves dependency from hfStatusSurfacingAndPreview to issueLongOpTransientCompletion;

    // Caught by the new tests (D0026 comprehensive-testing overhaul), NOT in the field — the intended
    // win: a MEDIUM correctness defect found by a fail-first regression test instead of a critique pass.
    part issueMergeCrlf : Issue { :>> id = "c0f1a5cc-e018-4a10-9b20-a1b2c3d4e018"; :>> title = "merge3 didn't normalize CRLF → cross-platform edits exploded into spurious whole-file conflicts"; :>> createdAt = "2026-07-14"; :>> createdBy = "ai"; :>> description = "src/merge.ts splitLines() split on raw \\n, leaving a trailing \\r on every CRLF line, so the LCS found ZERO common anchors between a CRLF base and an LF re-save — collapsing the whole file into one conflict region even when the real content edits didn't overlap. Obsidian vaults sync across Windows (CRLF) and macOS/Linux/mobile (LF), so this fired on nearly every cross-platform merge, undermining Merge as the 'nothing is lost' safe default in the vault-switch flow. Found by test/merge-eol.test.ts (authored it.fails, flipped to a passing regression on fix). FIX: normalize CRLF→LF before any comparison in merge3 (merged output already joins with \\n, so this is consistent, not lossy). Severity Medium. discoveredInField=false — caught pre-release by the new merge suite."; :>> discoveredInField = false; :>> relatedTask = "testHardeningClient"; :>> severity = Severity::Medium; }
    #Resolves dependency from testHardeningClient to issueMergeCrlf;

    part issueDockerfileEnvSecret : Issue { :>> id = "c0f1a5cc-e019-4a10-9b20-a1b2c3d4e019"; :>> title = "server Dockerfile baked SYNC_PASSWORD into an ENV instruction (persisted in image layers)"; :>> createdAt = "2026-07-15"; :>> createdBy = "ai"; :>> description = "The server Dockerfile set `ENV SYNC_PASSWORD=admin` (+ SYNC_USER=admin), which BuildKit flags SecretsUsedInArgOrEnv: an ENV value is persisted into the image layers (readable via `docker history`/`inspect`), so a credential in ENV leaks. Surfaced as a warning in the server-image CI build. Low real impact (the value was the well-known default 'admin', which the boot weak-password guard already REFUSES unless ALLOW_WEAK_ADMIN=1, so it was never a usable live credential), but it's a genuine hygiene defect. FIX: drop SYNC_USER/SYNC_PASSWORD from the image ENV (keep non-sensitive DATA_ROOT/BIND_ADDR); the code defaults (config.rs admin/admin) still apply and are still refused at boot, so the operator must provide a real password at RUNTIME (docker -e / compose / secret). Severity Low. discoveredInField=false (CI docker lint)."; :>> discoveredInField = false; :>> relatedTask = "postOverhaulHardening"; :>> severity = Severity::Low; }
    #Resolves dependency from postOverhaulHardening to issueDockerfileEnvSecret;

    part issueFalseAbsenceDelete : Issue { :>> id = "c0f1a5cc-e01a-4a10-9b20-a1b2c3d4e01a"; :>> title = "delete-remote tombstoned on absence-from-the-LISTING, not CONFIRMED absence (cloud-placeholder / failed-enumeration data-loss vector)"; :>> createdAt = "2026-07-15"; :>> createdBy = "wweatherholtz"; :>> description = "The batch reconcile path (reconcileAll/reconcileDelta) derived a file's local presence from io.list(), which UNDER-REPORTS when a directory fails to enumerate (ObsidianVaultIo.enumerateConfig swallowed the adapter.list error as an empty dir) or a cloud-drive placeholder (OneDrive Files-On-Demand) isn't hydrated. A still-present file then looked absent → locallyPresent=false DEFEATED the existing C1 read-failure guard (which requires locallyPresent) → decide()=delete-remote → an UNGUARDED tombstone (delete-remote had no absence/bulk guard), which on the next restart delete-locals fleet-wide. This is the SelfSync-side latent cause of the 'all plugins vanished from the list after restart' CLASS. NOTE: it did NOT cause the specific field report — that vault's server index had 0 tombstones (proving SelfSync deleted nothing there; its config sync was pointed at an offline local server), and the true cause was OneDrive Files-On-Demand dehydrating the plugin files so Obsidian couldn't read them at startup. But this is exactly the trap OneDrive-style placeholders + config sync ON + a reachable server would spring. FIX: delete-remote now requires CONFIRMED absence via a direct per-path probe (confirmedAbsent — io.exists/read, never the listing); an unreadable-but-existing file is KEPT. enumerateConfig now LOGS a dir-list failure instead of silently treating it as empty. Correct-by-construction, not a bulk guard (per the owner's explicit direction). Regression: reconcile.test 'CONFIRMED absence' (fail-first verified: guard disabled → the placeholder test fails; genuine deletes still propagate). Severity High (data-loss class). discoveredInField=false (found by analysis while diagnosing the OneDrive report)."; :>> discoveredInField = false; :>> relatedTask = "falseAbsenceDeleteFix"; :>> severity = Severity::High; }
    #Resolves dependency from falseAbsenceDeleteFix to issueFalseAbsenceDelete;

    part issueConfigListDisable : Issue { :>> id = "c0f1a5cc-e01b-4a10-9b20-a1b2c3d4e01b"; :>> title = "community-plugins.json synced as an opaque blob → a shorter synced copy DISABLES a locally-installed plugin"; :>> createdAt = "2026-07-15"; :>> createdBy = "wweatherholtz"; :>> description = "community-plugins.json is the SET of enabled community-plugin ids (and gates whether installed plugins RUN), but config sync treated it as an opaque whole-file blob resolved by taking ONE whole side. So adopting a shorter synced copy (a pull where the remote dropped an id, or a divergence resolved to 'remote') would DISABLE every plugin not in that list — including SelfSync's own id — even though the plugin is installed+enabled locally. This is the DISABLE half of the 'all my plugins vanished' class (distinct from issueFalseAbsenceDelete's DELETE half). Surfaced while diagnosing the OneDrive field report, where the owner explicitly asked for proper behavior rather than a guard. FIX (correct-by-construction): community-plugins.json is now UNION-merged (isEnabledListConfig + mergeEnabledPluginsJson in configsync.ts; a dedicated branch in reconcileOne) — a grow-only set of enabled ids. A pull/divergence keeps every locally-enabled id and adds the remote's, and pushes the union so the server converges; a read-only share keeps the union locally. Enables propagate; a disable does not (toggled per device) — the catastrophe-proof asymmetry the owner chose. Verified: configsync.test (mergeEnabledPluginsJson union/empty/null), reconcile.test (fail-first: a shorter pull keeps the local plugin + converges the server; adopts a longer list), and a real-Obsidian two-device e2e (configsync.pwspec: A's plugin propagates to B, B's own plugin not disabled). Severity High (availability/data class). discoveredInField=false."; :>> discoveredInField = false; :>> relatedTask = "configListSetMerge"; :>> severity = Severity::High; }
    #Resolves dependency from configListSetMerge to issueConfigListDisable;

    part issuePendingCountsDeclinedFiles : Issue { :>> id = "c0f1a5cc-f00c-4a10-9b20-a1b2c3d4f00c"; :>> title = "The pending-sync count includes remote files this device declined (config off / plugin not allowlisted) → a phantom count that never drains"; :>> createdAt = "2026-07-13"; :>> createdBy = "wweatherholtz"; :>> description = "FIELD: reopening a vault showed 20+ pending syncs that 'never do anything'; the server log showed login OK then no transfers. Root cause: reconcileAll/reconcileDelta pre-classified the pending set from remote-vs-base WITHOUT applying the accepts() filter, so a remote file this device is set NOT to sync (a config surface off, or a community plugin not in the allowlist) was counted as pending even though reconcileOne correctly SKIPS it — it can never transfer, so the count never drained (and on mobile, which backgrounds mid-pass, it looked permanently stuck). The user also had no way to see WHAT was waiting or learn that plugin sync is opt-in on BOTH ends. RESOLVED (1.0.39): the pending pre-classifier now excludes accepts()-filtered files in both paths (honest 'work this device will do'); those files are surfaced via a new onDeclined callback → a coalesced, change-only log ('N community plugins / config files on the server are NOT in this device's sync selection — enable them in Settings → Obsidian configuration to sync them here'), which both explains the count and tells the user how to adopt a plugin another vault added. Test: reconcile 'does NOT count a remote file this device DECLINES as pending'. Class: misleading state / discoverability."; :>> discoveredInField = true; :>> relatedTask = "pendingExcludesDeclined"; :>> severity = Severity::Medium; }
    #Resolves dependency from pendingExcludesDeclined to issuePendingCountsDeclinedFiles;

    part issueConfigSyncMobileLatency : Issue { :>> id = "c0f1a5cc-f00b-4a10-9b20-a1b2c3d4f00b"; :>> title = "Config sync is slow (~minutes) on mobile — the local-change detector is a 2-min periodic scan, and mobile suspends when backgrounded"; :>> createdAt = "2026-07-12"; :>> createdBy = "wweatherholtz"; :>> description = "FIELD: config sync felt like it took ~5 min on mobile. Not broken — DESKTOP is live (the low-level vault `raw` event fires on any .obsidian/ change → immediate push), but that event is unreliable on mobile (Capacitor), so mobile fell back to a periodic config-only re-hash gated at CONFIG_SCAN_INTERVAL_MS=120s; add mobile suspend-on-background (timers frozen) and the sender-side detection could take minutes. RESOLVED (1.0.35), user chose 'cheap fast scan': (1) reconcileLocalConfig now skips a file whose on-disk (size,mtime) match the stat stamp from the last time it equalled base — so the scan can run OFTEN without re-hashing every synced plugin's bytes; (2) CONFIG_SCAN_INTERVAL_MS 120s→30s; (3) a visibilitychange listener forces a config scan on app-resume (mobile) rather than waiting for the next tick. Detection drops ~2 min → ~30s (instant on reopen); the receiving device already pulled promptly via WS poke/poll. Tests: reconcile config-scan fast-path skip / new-file still-detected / stamp-then-skip. Class: latency (platform-inherent detection gap, mitigated)."; :>> discoveredInField = true; :>> relatedTask = "fastCheapConfigScan"; :>> severity = Severity::Low; }
    #Resolves dependency from fastCheapConfigScan to issueConfigSyncMobileLatency;
}
