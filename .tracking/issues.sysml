    // =====================================================================
    // FIELD DATA-LOSS ESCAPE (2026-07-06): the owner switched a populated vault onto a new build /
    // wrong server; the client reported "kept 2 local files" but then DELETED every local file.
    // Root cause + the test-coverage gap that let it ship, recorded per D0047 (a recurrable
    // correction MUST become a tracked Issue + a permanent guard — here the guard is the realistic
    // tombstone-modeling harness + a regression test that reproduces the exact sequence).
    // Both resolved by deleteLocalTombstoneGate (0.10.25).
    // =====================================================================
    part issueDeleteOnAbsence : Issue {
        :>> id = "c0f1a5cc-9801-4a10-9b20-a1b2c3d49801";
        :>> title = "delete-local fired on a file's ABSENCE from the remote, not a real tombstone — wrong/empty server silently wiped the vault";
        :>> createdAt = "2026-07-06";
        :>> createdBy = "wweatherholtz";
        :>> description = "CRITICAL field data-loss: reconcile.decide() returned delete-local whenever a file present locally with an unchanged base was ABSENT from the remote (L!=null, R==null, L==B). Pointing a populated vault at a WRONG / FRESH / RESTORED server (a server that legitimately lacks our files but has issued NO deletion tombstones for them) therefore read every local file as a remote deletion and removed it. The one-shot C2 empty-server guard did not survive across reconcile passes — the client's own pushes made the remote non-empty on the second pass, disarming it — so even the '(server said it kept 2 local files)' log was immediately undone by the next reconcile (v1->v13). Fix: deletion is now TOMBSTONE-AUTHORITATIVE — reconcileOne takes a hasTombstone(path) predicate (reconcileAll from resp.deletes, reconcilePath from manifest.deletes); on absence WITHOUT a tombstone the file is RESTORED (pushed back), and it is removed ONLY when the server genuinely tombstoned it. Absence is never proof of deletion.";
        :>> discoveredInField = true;
        :>> relatedTask = "deleteLocalTombstoneGate";
        :>> severity = Severity::High;
    }
    part issueDeleteTestGap : Issue {
        :>> id = "c0f1a5cc-9802-4a10-9b20-a1b2c3d49802";
        :>> title = "The reconcile test suite CODIFIED the absence-delete bug and never covered a vault switch onto a wrong/empty server";
        :>> createdAt = "2026-07-06";
        :>> createdBy = "wweatherholtz";
        :>> description = "The 181-test suite missed the data-loss because the fake server modeled deletion as mere ABSENCE (files.delete with no tombstone), so tests could not distinguish a real deletion from a file the server never had — and TWO tests actively asserted the buggy delete-on-absence as correct behavior. Coverage was happy-path (deletion propagation) + a single-pass empty-server guard; nothing exercised the two-pass 'switch to a wrong/empty/restored server' sequence that reproduces in the field. Fix (the permanent guard, D0047): the fake server now models tombstones (deletions[] with versions; changes() returns them), the two mis-asserting tests were rewritten to correct tombstone semantics, and a DATA-LOSS REGRESSION test reproduces the exact field sequence (Welcome.md + 'test file.md' survive two reconciles against a wrong/empty server). Also hardened the orchestration seam: main.ts injection seams + an obsidian stub let plugin-wiring.test.ts cover the wiring, and the e2e harness was repaired (ALLOW_WEAK_ADMIN + createVault for protocol-6).";
        :>> discoveredInField = true;
        :>> relatedTask = "deleteLocalTombstoneGate";
        :>> severity = Severity::High;
    }
    #Resolves dependency from deleteLocalTombstoneGate to issueDeleteOnAbsence;
    #Resolves dependency from deleteLocalTombstoneGate to issueDeleteTestGap;

    // =====================================================================
    // TIMING CRUTCHES (the AI-baked-in arbitrary-timing anti-pattern the owner flagged, 2026-07-06):
    // two places where behavior was gated on a fabricated time/count guess rather than on the actual
    // condition. Removed in 0.10.26 (preReleaseHardening) — recorded so the anti-pattern is tracked,
    // not just quietly fixed.
    // =====================================================================
    part issueTokenTtlCrutch : Issue {
        :>> id = "c0f1a5cc-9803-4a10-9b20-a1b2c3d49803";
        :>> title = "Token validity was guessed via a 30s 'recently-validated' TTL + a proactive probe, not driven by the server";
        :>> createdAt = "2026-07-06";
        :>> createdBy = "wweatherholtz";
        :>> description = "acquireToken probed listVaults to 'validate' the stored token and cached that result for a fabricated 30-second window, skipping re-probes within it. The TTL is a guess: a token can be revoked/expire the instant after a probe, so the cache neither guarantees validity nor is needed — it's the AI-timing anti-pattern (bake in a number to paper over not modeling the real condition). Fixed: the token is used OPTIMISTICALLY and validity is the server's actual answer — a real 401 triggers a single reactive re-login (withAuth wraps the account calls; doConnect retries status() once). No probe, no TTL.";
        :>> discoveredInField = false;
        :>> relatedTask = "preReleaseHardening";
        :>> severity = Severity::Low;
    }
    part issueConfigScanPollCrutch : Issue {
        :>> id = "c0f1a5cc-9804-4a10-9b20-a1b2c3d49804";
        :>> title = "The periodic config-aware reconcile fired every Nth POLL (a tick count), not on a wall-clock bound";
        :>> createdAt = "2026-07-06";
        :>> createdBy = "wweatherholtz";
        :>> description = "The config-scan safety-net reconcile was gated on CONFIG_SCAN_EVERY_POLLS=8 — a decrement-per-poll counter. Coupling a real latency requirement ('detect a config change within ~N seconds') to an arbitrary poll count is the timing anti-pattern: change the poll cadence and the actual detection latency silently changes. Fixed: gate on a CONFIG_SCAN_INTERVAL_MS wall-clock bound (Date.now() - lastConfigScanAt), which states the real requirement and is stable regardless of poll cadence.";
        :>> discoveredInField = false;
        :>> relatedTask = "preReleaseHardening";
        :>> severity = Severity::Low;
    }
    #Resolves dependency from preReleaseHardening to issueTokenTtlCrutch;
    #Resolves dependency from preReleaseHardening to issueConfigScanPollCrutch;

    // =====================================================================
    // ROUND 6 — a SIXTH fresh 3-lens critique (independent DI/security/concurrency critics) vs the
    // 0.10.26 code, 2026-07-07. Did NOT converge: 9 findings, mostly NEW interactions introduced by
    // the 0.10.24 FSM refactor + the 0.10.26 CAS/reactive-token work. 8 fixed + shipped 0.10.27
    // (#Resolves round6CriticFixes); 1 Low accepted (D0018). A tracked follow-up (historyRebase)
    // is the proper bound that replaces the removed tombstone cap.
    // =====================================================================
    part issueTombstoneResurrection : Issue { :>> id = "c0f1a5cc-9a01-4a10-9b20-a1b2c3d49a01"; :>> title = "Arbitrary tombstone cap (MAX_TOMBSTONES) resurrects deleted files under tombstone-authoritative delete"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R6#1 (HIGH): the server capped retained deletion tombstones at 10,000 on the pre-0.10.25 premise that 'a full reconcile infers deletion from absence' — a premise 0.10.25 INVERTED (absence -> restore, not delete). A long-offline client returning after >10k deletions finds the tombstone compacted away, reads the genuine deletion as 'server never had it', and RE-UPLOADS the file — resurrecting it fleet-wide (induced, user-perceived integrity violation, though not byte-loss). Two subsystems hardened in different rounds against opposite failure modes contradicted each other. Fixed 0.10.27: removed the arbitrary cap; tombstones are durable, so a genuine deletion is always distinguishable from a wrong/fresh server. The proper bound on growth is a deliberate history rebase (historyRebase), not an arbitrary count."; :>> discoveredInField = false; :>> relatedTask = "round6CriticFixes"; :>> severity = Severity::High; }
    part issueUnboundedTombstones : Issue { :>> id = "c0f1a5cc-9a02-4a10-9b20-a1b2c3d49a02"; :>> title = "Tombstones now grow unbounded until a history-rebase mechanism exists"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "Consequence of removing the MAX_TOMBSTONES cap (issueTombstoneResurrection): the deletions Vec now grows without an automatic bound. Accepted as the lesser evil (each tombstone is tiny — a path + a u64 — so realistic vaults are unaffected for a long time, and an arbitrary cap silently corrupted deletion semantics). The correct, non-arbitrary bound is a deliberate HISTORY REBASE: reset history to a floor version, expose that floor as a client horizon, and have a client whose cursor is below it do a PROMPTED reconcile instead of auto-restoring. Tracked as historyRebase (open)."; :>> discoveredInField = false; :>> relatedTask = "historyRebase"; :>> severity = Severity::Low; }
    part issueCasEventOffline : Issue { :>> id = "c0f1a5cc-9a03-4a10-9b20-a1b2c3d49a03"; :>> title = "A CAS 409 on the single-path event reconcile flaps the engine offline (regression from 0.10.26 CAS)"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R6#1 (HIGH): reconcileAll isolates a per-file CommitConflictError (skip -> merge next pass), but reconcilePath had no such guard, and the SyncEngine turns any thrown effect into failToOffline. So a routine same-file concurrent edit (the common desktop path) — which the 0.10.26 CAS work made 409 — dropped the client to offline + backoff, flapping on repeated edits. Fixed 0.10.27: reconcilePath isolates a CommitConflictError like reconcileAll (leave base unchanged -> next reconcile merges); any OTHER error still propagates -> offline."; :>> discoveredInField = false; :>> relatedTask = "round6CriticFixes"; :>> severity = Severity::High; }
    part issueOwnerDirectionRce : Issue { :>> id = "c0f1a5cc-9a04-4a10-9b20-a1b2c3d49a04"; :>> title = "SEC-3 gate's owner-direction hole: a readWrite peer's plugin code auto-executes on the vault owner"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R6#1 (HIGH): the config-apply gate only suppressed auto-enable when vaultOwner was set (i.e. syncing a NON-owned vault). But a vault you OWN and share readWrite also holds an untrusted writer's content — a peer commits .obsidian/plugins/<id>/main.js and the owner's client auto-disables+enables the plugin, executing the peer's code (RCE, full Node access). The SEC-3 predicate was written too narrowly ('non-owned vault') vs the real one ('any vault with an untrusted writer'). Fixed 0.10.27: flushConfigReload never auto-enables synced plugin code for ANY vault — the user reloads manually. Refines STPA UCA-7 / SR-5."; :>> discoveredInField = false; :>> relatedTask = "round6CriticFixes"; :>> severity = Severity::High; }
    part issueCssInjection : Issue { :>> id = "c0f1a5cc-9a05-4a10-9b20-a1b2c3d49a05"; :>> title = "Synced theme/snippet CSS is auto-applied with no trust gate (injection via un-CSP'd renderer)"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R6#2 (MED): unlike the plugin branch, the appearance/theme/snippet CSS branch of flushConfigReload had NO ownership guard at all — it unconditionally called customCss.loadData/loadSnippets for any vault. A peer/owner commits malicious CSS; Obsidian's un-CSP'd renderer allows url()/attribute-selector exfil + phishing overlays. Fixed 0.10.27: synced CSS is never auto-applied; the user reloads to apply."; :>> discoveredInField = false; :>> relatedTask = "round6CriticFixes"; :>> severity = Severity::Medium; }
    part issueReloginRace : Issue { :>> id = "c0f1a5cc-9a06-4a10-9b20-a1b2c3d49a06"; :>> title = "Concurrent re-login race clears the password mid-flight (spurious 'session expired' + orphan token)"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R6#3 (MED): freshLogin READS the password (loginRemote) then destructively CLEARS it (token-only mode); the engine's reactive-401 path (doConnect) and the non-engine withAuth path (setup/switch modals) can both run it concurrently — a read-modify-write race across await with two entrants. The second reads an emptied password -> spurious 'session expired' prompt while a login is actually succeeding, minting an orphan token. Fixed 0.10.27: freshLogin is single-flight (concurrent calls coalesce into one login)."; :>> discoveredInField = false; :>> relatedTask = "round6CriticFixes"; :>> severity = Severity::Medium; }
    part issueFailToOfflineRecovery : Issue { :>> id = "c0f1a5cc-9a07-4a10-9b20-a1b2c3d49a07"; :>> title = "failToOffline leaves connected=true -> a WS redial + the backoff reconnect both run (two recovery paths)"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R6#2 (MED): failToOffline set state=offline + scheduled a reconnect but did NOT clear `connected`, so a WS `close` firing in the offline window enqueued {rews}, passed the `if(!connected) return` guard, and re-dialed a socket while the backoff reconnect was also pending — the exact redial-vs-reconnect double-recovery the FSM was meant to make impossible. Fixed 0.10.27: failToOffline sets connected=false, so path/remote/rews are ignored until the single backoff {connect} recovers."; :>> discoveredInField = false; :>> relatedTask = "round6CriticFixes"; :>> severity = Severity::Medium; }
    part issueReindexCollision : Issue { :>> id = "c0f1a5cc-9a08-4a10-9b20-a1b2c3d49a08"; :>> title = "reindex bypasses the case/Unicode collision + safe_rel_path guards that commit enforces"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "DI-R6#3 (MED): the PROTO-4 case/fold collision guard + safe_rel_path run only on the commit path. reindex (the other way index entries are created) ingested colliding names straight off the Linux bind-mount, minting two index keys that a case-insensitive/Unicode-folding client FS collapses to one file -> overwrite + phantom-delete churn. Fixed 0.10.27: reindex runs the same conflicting_or_unsafe_rels check (unsafe or fold-colliding names abort the reindex with a clear message)."; :>> discoveredInField = false; :>> relatedTask = "round6CriticFixes"; :>> severity = Severity::Medium; }
    part issueWsRedialSpurious : Issue { :>> id = "c0f1a5cc-9a09-4a10-9b20-a1b2c3d49a09"; :>> title = "doConnect's intentional ws.close() enqueues a spurious {rews} (extra redial after each reconnect)"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R6#4 (LOW): doConnect calls this.ws?.close() then awaits token acquisition; the close fires during the await while this.ws still references the old socket, so the close handler's only guard (this.ws !== ws) can't fire and it enqueues {rews} -> one extra WS teardown+redial after every reconnect over a live socket. Benign. Fixed 0.10.27: doConnect clears this.ws immediately after close()."; :>> discoveredInField = false; :>> relatedTask = "round6CriticFixes"; :>> severity = Severity::Low; }
    part issuePathSizeCoalesce : Issue { :>> id = "c0f1a5cc-9a0a-4a10-9b20-a1b2c3d49a0a"; :>> title = "path-event coalescing pins the first event's size, defeating the RAM/size gate at the boundary"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "CONC-R6#5 (LOW): the engine dedups queued {path} events by path only, keeping the STALE size; a file saved small then grown past the size gate before the queue drains is judged on the small size, so the pre-read RAM/size guard is bypassed (content stays correct via live re-read; only the OOM guard is defeated, a narrow mobile edge). Fixed 0.10.27: coalescing keeps the LARGER size."; :>> discoveredInField = false; :>> relatedTask = "round6CriticFixes"; :>> severity = Severity::Low; }
    part issueShareEnumeration : Issue { :>> id = "c0f1a5cc-9a0b-4a10-9b20-a1b2c3d49a0b"; :>> title = "Authenticated username-enumeration oracle via /api/admin/shares (400 'no such account' vs 200)"; :>> createdAt = "2026-07-07"; :>> createdBy = "wweatherholtz"; :>> description = "SEC-R6#3 (LOW, ACCEPTED): share_create returns a distinct 400 'no such account' vs 200 depending on whether the grantee exists, giving any authenticated user a present/absent oracle to enumerate accounts (the same oracle class de-oracled on /register). ACCEPT-RISK (decided in Round 6, not fixed): authenticated-only, the side effect is confined to the attacker's own vault, and a clear 'no such account' error is materially better UX for the legitimate typo case; a uniform error would degrade the common path for a low-value oracle on a self-hosted server. Revisit if registration ever becomes fully open + adversarial."; :>> discoveredInField = false; :>> relatedTask = "round6CriticFixes"; :>> severity = Severity::Low; }

