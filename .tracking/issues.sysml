    // ---- CMMC assessor round (2026-07, AC/IA/AU + SC/SI/CM). 5 FIXED + real-tested (critRoundCmmc),
    // 2 deferred (critRoundResidual). ----
    part issueCmmc2Mfa : Issue { :>> id = "c0f1a5cc-d001-4a10-9b20-a1b2c3d4d001"; :>> title = "IA.3.5.3 overstated MET — MFA not required for privileged accounts"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "ASSESSOR-CRITICAL: MFA was purely opt-in self-enrollment; nothing required a privileged account to have it (totp_enabled consulted only at login; admin_grant had no MFA precondition; bootstrap admin is password-only), so the 'MET' claim overstated the control ('USE MFA FOR privileged accounts'). RESOLVED: added REQUIRE_ADMIN_MFA=1 — require_admin denies a privileged account until it enrolls TOTP (enrollment reachable while blocked, no lockout); posture reworded to an operator-configured control (like TLS). Class: overstated MET / authz."; :>> discoveredInField = false; :>> relatedTask = "critRoundCmmc"; :>> severity = Severity::High; }
    part issueCmmc2AuditMfa : Issue { :>> id = "c0f1a5cc-d002-4a10-9b20-a1b2c3d4d002"; :>> title = "AU.3.3.1 — failed MFA enable/disable attempts not audited"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "A wrong-code MFA disable (a stolen-token probe to strip the second factor) and a failed enrollment-confirm emitted no audit event — only the success paths did. RESOLVED: mfa.rs emits MFA_DISABLE/MFA_ENABLE with outcome=FAILURE on the wrong-code branches. Class: audit coverage gap."; :>> discoveredInField = false; :>> relatedTask = "critRoundCmmc"; :>> severity = Severity::Medium; }
    part issueCmmc2WsPerUser : Issue { :>> id = "c0f1a5cc-d003-4a10-9b20-a1b2c3d4d003"; :>> title = "SC.3.13.1 — global WS budget with no per-user sub-cap (single-account notification DoS)"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "MAX_WS_CONNECTIONS was a single global cap, so one authenticated account could open all 512 sockets and deny change-notifications to every other user. RESOLVED: added a per-user WS sub-cap (MAX_WS_PER_USER=16) checked alongside the global reserve, released by the connection guard on every exit path. Class: authenticated availability."; :>> discoveredInField = false; :>> relatedTask = "critRoundCmmc"; :>> severity = Severity::Medium; }
    part issueCmmc2Cleartext : Issue { :>> id = "c0f1a5cc-d004-4a10-9b20-a1b2c3d4d004"; :>> title = "SC.3.13.8 — client cleartext-http refusal not complete across account calls"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "The 'whole channel' claim was overstated: only the sync constructor + login/register checked isInsecureRemote; the token-bearing account-management static methods (listVaults/createVault/changePassword/shares/myVaults) did not, so a persisted cleartext-remote baseUrl could transmit the token (and a new password) in the clear. RESOLVED: centralized the check in httpReq — every request refuses http-to-remote (loopback still allowed); 3.13.8 now genuinely whole-channel (met). Class: transmission confidentiality (was narrowly overstated)."; :>> discoveredInField = false; :>> relatedTask = "critRoundCmmc"; :>> severity = Severity::Medium; }
    part issueCmmc2BootGuard : Issue { :>> id = "c0f1a5cc-d005-4a10-9b20-a1b2c3d4d005"; :>> title = "CM.3.4.2 — boot guard rejected only the literal 'admin'"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "The secure-baseline boot refusal triggered only on the exact string 'admin'; SYNC_PASSWORD=password/admin123/a short pin booted without objection. RESOLVED: weak_admin_refused now rejects a known-weak set OR anything <8 chars (still gated by ALLOW_WEAK_ADMIN=1). Class: secure-baseline strengthening."; :>> discoveredInField = false; :>> relatedTask = "critRoundCmmc"; :>> severity = Severity::Low; }
    part issueCmmc2AuditSource : Issue { :>> id = "c0f1a5cc-d006-4a10-9b20-a1b2c3d4d006"; :>> title = "AU.3.3.2/3.3.8 — audit SOURCE spoofable + absent on authz-denied events"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "The audit source takes the leftmost X-Forwarded-For (client-spoofable unless the proxy replaces it), and the cross-tenant/require_admin denial events pass source='-' (IP not threaded into those choke-points). RESOLVED (high-value half): require_admin now threads the caller's ClientIp, so the privileged-function-DENIED events — the assessor's primary concern — carry the source. The lower-value per-vault read denials in scoped() keep source '-' (accepted: proxy-correlated by timestamp), and the XFF-trust remains the documented proxy contract (a spoofed XFF is only possible if the proxy doesn't overwrite it). Class: audit accountability."; :>> discoveredInField = false; :>> relatedTask = "critResidual2"; :>> severity = Severity::Medium; }
    part issueCmmc2MobileCodeWording : Issue { :>> id = "c0f1a5cc-d007-4a10-9b20-a1b2c3d4d007"; :>> title = "SC.3.13.13 — 'trust-prompt gate' wording describes a mechanism not in the reviewed code"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "The default-OFF plugin allowlist is real and correctly gates whether plugin CODE PROPAGATES, but the 3.13.13 phrasing 'never auto-executed (trust-prompt gate)' described an execution gate governed by Obsidian's own enable step, not SelfSync code. RESOLVED: the model rationale now reads 'community-plugin code does not propagate by default (per-plugin sync allowlist); execution is Obsidian's enable step'. Class: claim precision."; :>> discoveredInField = false; :>> relatedTask = "critResidualEasy"; :>> severity = Severity::Low; }
    #Resolves dependency from critRoundCmmc to issueCmmc2Mfa;
    #Resolves dependency from critRoundCmmc to issueCmmc2AuditMfa;
    #Resolves dependency from critRoundCmmc to issueCmmc2WsPerUser;
