    // Critique R8 (4-lens) residual — the two MED concurrency findings NOT fixed in the R8 batch
    // (0.10.35). The HIGH/MED findings that WERE fixed are enumerated + resolved in critiqueR8FixesDoD.
    part issueDoubleOpenRace : Issue { :>> id = "c0f1a5cc-9c01-4a10-9b20-a1b2c3d49c01"; :>> title = "Concurrent first-access to a cold corrupt vault can leave the cached handle stuck corrupt (SQLITE_BUSY)"; :>> createdAt = "2026-07-08"; :>> createdBy = "wweatherholtz"; :>> description = "Conc-R8 M1 (MED): state.vault() releases the ns-map lock across Vault::open, so two concurrent first-accesses to the same cold, corrupt (user,vault) both run reindex on separate SQLite connections. SQLite serializes writers → one hits SQLITE_BUSY, its reindex errors, and that Vault stays corrupt=true; if it wins the or_insert race it's the CACHED handle → every sync op 503s until a manual reindex, though the DB is fine. Fix: a per-(user,vault) open/reindex lock so only one thread opens. Low real-world likelihood (needs simultaneous cold first-access to the same corrupt vault)."; :>> discoveredInField = false; :>> relatedTask = "serverConcurrencyResidual"; :>> severity = Severity::Medium; }
    part issueChangesOnAsyncWorker : Issue { :>> id = "c0f1a5cc-9c02-4a10-9b20-a1b2c3d49c02"; :>> title = "Full-manifest changes(since=0) scans SQLite under the read lock on the async worker"; :>> createdAt = "2026-07-08"; :>> createdBy = "wweatherholtz"; :>> description = "Conc-R8 M2 (MED): the changes handler holds rlock(vault) and runs SqliteIndex::changes on the async worker; for since=0 (first sync / full reconcile) that's a whole-files-table scan blocking a runtime worker for its duration (the write ops correctly use spawn_blocking; this read path does not). No deadlock (no await under the guard). Fix: offload the full-manifest read to the blocking pool. Lower-impact cousin of the now-fixed cold-open-on-worker (Conc-H1)."; :>> discoveredInField = false; :>> relatedTask = "serverConcurrencyResidual"; :>> severity = Severity::Medium; }
    #Resolves dependency from serverConcurrencyResidual to issueDoubleOpenRace;
    #Resolves dependency from serverConcurrencyResidual to issueChangesOnAsyncWorker;

    // ---- CMMC / NIST SP 800-171 rev2 POA&M: the 5 code-addressable compliance gaps surfaced by
    // modeling the 110 controls (see .tracking/compliance/nist-800-171.sysml + docs/cmmc-posture.md).
    // Triaged (accounted-for) via the open cmmcComplianceBacklog action; honestly OPEN (planned work /
    // operator decision), not resolved. ----
    part issueCmmcMfa : Issue { :>> id = "c0f1a5cc-a001-4a10-9b20-a1b2c3d4a001"; :>> title = "3.5.3: No multifactor authentication (IA)"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "No multifactor authentication (IA.3.5.3). RESOLVED: TOTP (RFC 6238) second factor + single-use recovery codes for privileged (server-admin) accounts — self-enrolled via /admin, verified at login. Self-contained crypto (totp.rs, no new deps) pinned to RFC 4231/6238 test vectors. Real tests: totp.rs totp_rfc6238_vectors + hmac_sha1_rfc4231; admin.rs mfa_totp_full_lifecycle. Non-privileged (plugin) MFA is a follow-up."; :>> discoveredInField = false; :>> relatedTask = "cmmcMfa"; :>> severity = Severity::Medium; }
    part issueCmmcPwReuse : Issue { :>> id = "c0f1a5cc-a002-4a10-9b20-a1b2c3d4a002"; :>> title = "3.5.8: No password-reuse history (IA)"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "No password-reuse history (IA.3.5.8). RESOLVED: users.rs retains the last 5 argon2 hashes and change_password rejects reuse of the current or any recent password. Real tests: users.rs reuse_history_rejects_current_and_recent_passwords + admin.rs password_change_rejects_reuse_of_a_recent_password."; :>> discoveredInField = false; :>> relatedTask = "cmmcForcedChangeReuse"; :>> severity = Severity::Medium; }
    part issueCmmcForcedChange : Issue { :>> id = "c0f1a5cc-a003-4a10-9b20-a1b2c3d4a003"; :>> title = "3.5.9: No forced-change-on-reset (IA)"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "No forced-change-on-reset (IA.3.5.9). RESOLVED: admin create/reset flags must_change; the AuthToken extractor blocks every route but change-password/logout until the account sets a new password. Real tests: admin.rs admin_created_account_is_forced_to_change_password_before_use + users.rs must_change_flag_set_clear_and_cleared_on_remove."; :>> discoveredInField = false; :>> relatedTask = "cmmcForcedChangeReuse"; :>> severity = Severity::Medium; }
    part issueCmmcFips : Issue { :>> id = "c0f1a5cc-a004-4a10-9b20-a1b2c3d4a004"; :>> title = "3.13.11: Crypto is not FIPS-validated (SC)"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "Crypto is not FIPS-validated (SC.3.13.11). Decision: FIPS provider if genuine CUI is stored."; :>> discoveredInField = false; :>> relatedTask = "cmmcComplianceBacklog"; :>> severity = Severity::Medium; }
    part issueCmmcAtRest : Issue { :>> id = "c0f1a5cc-a005-4a10-9b20-a1b2c3d4a005"; :>> title = "3.13.16: CUI at rest is plaintext (SC)"; :>> createdAt = "2026-07-10"; :>> createdBy = "wweatherholtz"; :>> description = "CUI at rest is plaintext (SC.3.13.16). Near-term: operator volume encryption; E2EE deferred."; :>> discoveredInField = false; :>> relatedTask = "cmmcComplianceBacklog"; :>> severity = Severity::Medium; }
