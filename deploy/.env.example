# SelfSync deployment config — copy to `.env` next to docker-compose.yml, fill in, then
#   docker compose up -d
# The values here are PLACEHOLDERS. docker-compose.yml requires all three (it fails fast if
# any is unset), so there are no insecure baked-in defaults to forget to change.

# The public hostname you'll point Obsidian at. Caddy provisions a Let's Encrypt cert for it,
# so it must resolve to this host (DNS A/AAAA) and 80/443 must be reachable from the internet.
SELFSYNC_DOMAIN=sync.example.com

# The server-admin account. Pick your own username — it does NOT have to be "admin".
SYNC_USER=changeme

# A LONG random password (e.g. `openssl rand -base64 24`). The server REFUSES to start with the
# weak "admin" password unless ALLOW_WEAK_ADMIN=1 is set (intended only for a throwaway LAN box).
SYNC_PASSWORD=change-me-to-a-long-random-secret
